<ehcache xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="EE_Cache_Config.xsd">
    
   <diskStore path="java.io.tmpdir"/>
    <cacheManagerEventListenerFactory class="" properties=""/>
    <defaultCache
            maxElementsInMemory="100"
            eternal="false"
            timeToIdleSeconds="600"
            timeToLiveSeconds="600"
            overflowToDisk="false"
            diskPersistent="false"
            diskExpiryThreadIntervalSeconds="120"
            memoryStoreEvictionPolicy="LRU"
            />
    <cache name="CACHE_BROKER"
           maxElementsInMemory="10000"
           eternal="true"
           timeToIdleSeconds="600"
           timeToLiveSeconds="600"
           overflowToDisk="false" />
   
       <cache name="CACHE_LISTENER"
           maxElementsInMemory="10000"
           eternal="true"
           timeToIdleSeconds="600"
           timeToLiveSeconds="600"
           overflowToDisk="false" />
           
       <cache name="CACHE_SENDER"
           maxElementsInMemory="10000"
           eternal="true"
           timeToIdleSeconds="600"
           timeToLiveSeconds="600"
           overflowToDisk="false" />
           
       <cache name="CACHE_SERVICE"
           maxElementsInMemory="10000"
           eternal="true"
           timeToIdleSeconds="600"
           timeToLiveSeconds="600"
           overflowToDisk="false" />
           
       <cache name="CACHE_WEB_ACTION"
           maxElementsInMemory="10000"
           eternal="true"
           timeToIdleSeconds="600"
           timeToLiveSeconds="600"
           overflowToDisk="false" />
 </ehcache>