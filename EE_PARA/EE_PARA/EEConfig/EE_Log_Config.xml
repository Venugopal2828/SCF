<?xml version="1.0" encoding="UTF-8"?>  
<!-- EE-10299 -->
<Configuration status="OFF">  
    <Properties>
        <Property name="user_level">user_level_log</Property>
        <Property name="sys_level">system_level_log</Property>
        <Property name="logInfix"></Property><!--EE-8465   default is null   example: _10.39.105.163_9080 -->
        <Property name="default_path" value="${sys:ee.input.dir}"/>
	<!-- <Property name="default_path" value="${sys:user.dir}"/> --> <!-- default_path FOR Wildfly & Weblogic -->
        <Property name="LOG_PATTERN" value="%n[start] [%p] [%d{yyyy-MM-dd HH:mm:ss.SSS}] [%X{userID}] %msg [end]%n"/>
        <!-- Log file size, beyond which it will be compressed -->
        <Property name="LOG_MAX_SIZE" value="10 MB"/>   
        <Property name="TIME_BASED_INTERVAL" value="1"/>
        <Property name="CHARSET" value="UTF-8"/>
    </Properties>
    <Appenders>  
        <Console name="Console" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>  
        </Console> 
        <Console name="SysConsole" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>  
        </Console> 
        <!-- LOG for DB Appenders START -->
        <Console name="EELOGforDBAppender" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %%n"/>  
        </Console> 
        <Console name="SQLLOGforDBAppender" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %%n"/>  
        </Console> 
        <Console name="BATCHLOGforDBAppender" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %%n"/>  
        </Console>
        <Console name="TASKLOGforDBAppender" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %%n"/>  
        </Console>
        <Console name="LMTSLOGforDBAppender" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %%n"/>  
        </Console> 
        <Console name="ACCESSLOGINLOGforDBAppender" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %%n"/>  
        </Console> 
         <Console name="SECULOGforDBAppender" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %%n"/>  
        </Console>
         <Console name="STANLOGforDBAppender" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %%n"/>  
        </Console>
          <Console name="ACTLOGforDBAppender" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %%n"/>  
        </Console>
        
        <!-- LOG for DB Appenders END -->
        <Routing name="EELOGAppender">
            <Routes pattern="$${ctx:userID}">
                <Route>
                <!-- filePattern="${default_path}/EELog/$${date:yyyy-MM-dd}/${user_level}/%d{yyyy-MM-dd}_[${ctx:userID}]${logInfix}_EELog-%i.log"--><!-- for Logs file splited -->
                    <RollingFile name="EELogRolling" 
                                   filePattern="${default_path}/EELog/$${date:yyyy-MM-dd}/${user_level}/%d{yyyy-MM-dd}_[${ctx:userID}]${logInfix}_EELog.log" 
                                   immediateFlush="true" 
                                   append="true">

                        <PatternLayout charset="${CHARSET}" pattern="${LOG_PATTERN}"/>
                        <Policies>
                            <!--interval  to specify how often to scroll-->
                            <TimeBasedTriggeringPolicy interval="${TIME_BASED_INTERVAL}"/>
                            <SizeBasedTriggeringPolicy size="${LOG_MAX_SIZE}"/>
                        </Policies>
                        <!-- DefaultRolloverStrategy if not set，By default, up to 7 files are saved in the same folder-->
                        <DirectWriteRolloverStrategy maxFiles="10"/>
                    </RollingFile>
                </Route>
            </Routes>
        </Routing>
        
