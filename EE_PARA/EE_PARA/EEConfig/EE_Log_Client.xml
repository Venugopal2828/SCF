<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">
<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/">
	<!--@ref EE-8345 @date 2016-09-06 @author mec.tang add_S-->
	<appender name="logServer" class="com.cs.base.log.CSSocketAppender">
		<!-- Single Log Server Mode -->
		<!--
		<param name="Port" value="4712"/>
		<param name="RemoteHost" value="10.39.105.232"/>
		<param name="ReconnectionDelay" value="1000"/>	
		<param name="ReconnectionTryTimes" value="5"/>
		-->
		
		<!--Multiple Log Servers Mode -->
		<!-- EE-8476 -->
		<!--<param name="LogServers" value="10.39.105.30:4712;10.39.105.31:4712;" />-->
		<param name="RemoteHost" value="10.39.105.232"/>
		<param name="Port" value="4712"/>
		<param name="ReconnectionDelay" value="1000"/>	
		<param name="ReconnectionTryTimes" value="5"/>
		<param name="RemoteHostWeb" value="10.39.103.100"/>
		<param name="RemoteHostPort" value="9083"/>
		<param name="WebContent" value="GTS"/>
		<!-- EE-8476 -->
	</appender>
	
	<root>
		<level value="DEBUG" />
		<appender-ref ref="logServer"/>
	</root>
	<!--@ref EE-8345 @date 2016-09-06 @author mec.tang add_E-->
</log4j:configuration>
