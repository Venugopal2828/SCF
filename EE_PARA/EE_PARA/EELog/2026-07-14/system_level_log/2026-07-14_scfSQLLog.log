[start] [DEBUG] [2026-07-14 14:00:50.030] [System] SELECT  DISTINCT M.C_MAIN_REF  FROM EXIMTRX.FADA_MASTER M inner join INVC_MASTER I  ON M.C_MAIN_REF = I.FSBC_REF  WHERE  (  (M.FA_RELATION_STATUS ='Active' AND M.INV_FIN_MODE ='INV') OR ((M.FA_RELATION_STATUS ='Deactive' or M.FA_RELATION_STATUS ='Active') AND M.INV_FIN_MODE ='POOL') )  AND I.OVD_DT IS NULL AND I.C_TRX_STATUS = 'M' AND I.FA_DOC_TYPE = '1' AND I.FA_DOC_STATUS <>'Reject' AND (I.FA_PMT_TYPE <>'PMT' OR I.FA_PMT_TYPE IS NULL) AND I.FA_DOC_BAL >0  AND I.FA_DOC_DUE_DT + M.GRACE_DAYS = '2026-07-14' [end]

[start] [DEBUG] [2026-07-14 14:00:50.100] [System] UPDATE EXIMTRX.INVC_MASTER F  SET INV_POOL_STATUS = 'OUT' ,OVD_DT= 'Tue Jul 14 14:00:50 GST 2026'  WHERE EXISTS (  SELECT 1 FROM  (  SELECT M.C_MAIN_REF,I.FSBC_REF,I.FA_DOC_REF  FROM EXIMTRX.FADA_MASTER M inner join EXIMTRX.INVC_MASTER I  ON M.C_MAIN_REF = I.FSBC_REF  WHERE M.INV_FIN_MODE ='POOL' AND I.INV_POOL_STATUS='IN' AND I.C_TRX_STATUS = 'M' AND I.FA_DOC_TYPE = '1' AND I.FA_DOC_STATUS <>'Reject' AND (I.FA_PMT_TYPE <>'PMT' OR I.FA_PMT_TYPE IS NULL) AND I.FA_DOC_BAL >0  AND I.FA_DOC_DUE_DT + M.GRACE_DAYS = '2026-07-14' AND I.OVD_DT IS NULL  ) R  WHERE F.FSBC_REF=R.C_MAIN_REF AND F.FA_DOC_REF=R.FA_DOC_REF ) [end]

[start] [DEBUG] [2026-07-14 14:00:50.157] [System] UPDATE EXIMTRX.INVC_MASTER F  SET OVD_DT= 'Tue Jul 14 14:00:50 GST 2026'  WHERE EXISTS (  SELECT 1 FROM  (  SELECT M.C_MAIN_REF,I.FSBC_REF,I.FA_DOC_REF  FROM EXIMTRX.FADA_MASTER M inner join EXIMTRX.INVC_MASTER I  ON M.C_MAIN_REF = I.FSBC_REF  WHERE M.INV_FIN_MODE ='INV' AND I.C_TRX_STATUS = 'M' AND I.FA_DOC_TYPE = '1' AND I.FA_DOC_STATUS <>'Reject' AND (I.FA_PMT_TYPE <>'PMT' OR I.FA_PMT_TYPE IS NULL) AND I.FA_DOC_BAL >0  AND I.FA_DOC_DUE_DT + M.GRACE_DAYS = '2026-07-14' AND I.OVD_DT IS NULL  ) R  WHERE F.FSBC_REF=R.C_MAIN_REF AND F.FA_DOC_REF=R.FA_DOC_REF ) [end]

[start] [DEBUG] [2026-07-14 14:00:50.210] [System] UPDATE EXIMTRX.FADA_MASTER F  SET (FA_TTL_ADJ_BAL, AMT_AVAL_FOR_FUNDING)=  (  SELECT F.FA_TTL_ADJ_BAL-FA_ADJ_BAL,ROUND( (F.FA_TTL_ADJ_BAL-FA_ADJ_BAL)* F.FA_MAX_LOAN_PERC / 100,CASE  WHEN FA_LMT_CCY IN ('JPY', 'SGD', 'VND', 'YYY' ) THEN 0  WHEN FA_LMT_CCY IN ('AAB' ) THEN 3  ELSE 2  END  )  FROM  (  SELECT  FSBC_REF AS C_MAIN_REF  ,SUM(FA_ADJ_BAL) FA_ADJ_BAL  FROM EXIMTRX.INVC_MASTER WHERE INV_POOL_STATUS = 'OUT' AND OVD_DT = 'Tue Jul 14 14:00:50 GST 2026' GROUP BY FSBC_REF ) R  WHERE F.C_MAIN_REF=R.C_MAIN_REF  )  WHERE EXISTS ( SELECT 1 FROM  (  SELECT FSBC_REF AS C_MAIN_REF  FROM EXIMTRX.INVC_MASTER WHERE INV_POOL_STATUS = 'OUT' AND OVD_DT = 'Tue Jul 14 14:00:50 GST 2026') R  WHERE F.C_MAIN_REF=R.C_MAIN_REF) [end]

