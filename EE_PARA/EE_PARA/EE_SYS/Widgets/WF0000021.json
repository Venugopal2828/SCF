		"data": {
			"sql": "SELECT C_UNIT_CODE, FA_SEL_ID AS CUSTOMER_ID, SUM(FA_TTL_LOAN_AMT) AS VL FROM EXIMTRX.FAEF_MASTER WHERE (FA_TTL_LOAN_AMT = FA_TTL_LOAN_AMT AND FA_SEL_ID = FA_SEL_ID) AND (C_TRX_STATUS = 'M' AND FA_TTL_LOAN_AMT IS NOT NULL) GROUP BY C_UNIT_CODE, FA_SEL_ID fetch first 20 rows only",
