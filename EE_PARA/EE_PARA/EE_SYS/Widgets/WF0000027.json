		"data": {
			"sql": "SELECT C_UNIT_CODE, FA_SEL_ID AS CUSTOMER_ID, ROUND(SUM(FA_PAID_INT_SUM)) AS VL FROM EXIMTRX.FAEF_MASTER WHERE (FA_PAID_INT_SUM = FA_PAID_INT_SUM AND FA_SEL_ID = FA_SEL_ID) AND (C_TRX_STATUS = 'M' AND FA_PAID_INT_SUM IS NOT NULL)  GROUP BY C_UNIT_CODE, FA_SEL_ID  ORDER BY VL DESC fetch first 20 rows only",
