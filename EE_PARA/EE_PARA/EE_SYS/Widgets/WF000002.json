					"pie": "{\"visualMap\":{\"colors\":[\"#4caf50\",\"#FCDC00\",\"#FB9E00\",\"#fc5c65\"],\"values\":[0,1,3,10]}}",
					"scatter": "{\"xAxis\":{\"name\":\"Number of days\"},\"visualMap\":{\"colors\":[\"#4caf50\",\"#FB9E00\",\"#fc5c65\"],\"values\":[0,1,3,10]}}",
					"effectScatter": "{\"xAxis\":{\"name\":\"Number of days\"},\"visualMap\":{\"colors\":[\"#4caf50\",\"#FB9E00\",\"#fc5c65\"],\"values\":[0,1,3,10]}}"
				}
