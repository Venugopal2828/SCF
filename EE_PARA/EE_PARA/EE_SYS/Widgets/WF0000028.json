		"data": {
			"sql": "SELECT C_UNIT_CODE, FA_PMT_CCY AS CURRENCY, ROUND(SUM(FA_PAID_INT_SUM)) AS VL FROM EXIMTRX.FAEF_PMT WHERE (FA_PAID_INT_SUM = FA_PAID_INT_SUM AND FA_PMT_CCY = FA_PMT_CCY) AND (C_TRX_STATUS = 'M' AND FA_PAID_INT_SUM IS NOT NULL)  GROUP BY C_UNIT_CODE, FA_PMT_CCY  ORDER BY SUM(FA_PAID_INT_SUM) DESC fetch first 20 rows only",
			"dataSetField": "C_UNIT_CODE",
			"nameField": "CURRENCY",
