<?xml version="1.0" encoding="UTF-8"?>
<WIDGET NAME="total_invoices">
	<PATTERN>
		<TYPE>table</TYPE>
		<TITLE>total invoices</TITLE>
		<RENDERCONTROL>topdiv</RENDERCONTROL>
		<AXIS/>
		<PERIOD Mapping_Field="D_CREA_DATE" Period_value="L">100</PERIOD>
		<!-- Interval = "NEXT/LAST" X MONTHS -->
		<INTERVAL/>
	</PATTERN>
	<MAP_TBL>
		<TABLES>
			<TABLE ALIAS="" schema="%EXIMTRX%">GTEE_MASTER</TABLE>
		</TABLES>
		<FIELDS>
			<FIELD DESC="C_USER_ID" FIELD="C_USER_ID" TBL_ALIAS="" TYPE="" HIDDEN = "" DBFUNC=""></FIELD>
            
            <FIELD DESC="GTEE_CCY" FIELD="GTEE_CCY" TBL_ALIAS="" TYPE="" DBFUNC=""></FIELD>
            <FIELD DESC="GTEE_AMT" FIELD="GTEE_AMT" TBL_ALIAS="" TYPE="" DBFUNC="SUM">
			<!--criteria field-->
				<GROUPBY>C_USER_ID,GTEE_CCY</GROUPBY>
			</FIELD>
            <FIELD DESC="MRGN_AC_AMT" FIELD="MRGN_AC_AMT" TBL_ALIAS="" TYPE="" DBFUNC="SUM">
			    <GROUPBY>C_USER_ID,GTEE_CCY</GROUPBY>
			</FIELD>
			<FIELD DESC="APPL_CUST_BK" FIELD="APPL_CUST_BK" TBL_ALIAS="" TYPE="" DBFUNC=""></FIELD>
			<FIELD DESC="GTEE_BAL" FIELD="GTEE_BAL" TBL_ALIAS="" TYPE="" DBFUNC="SUM">	
			    <GROUPBY>C_USER_ID,GTEE_CCY,APPL_CUST_BK</GROUPBY>
				<CriFld>
			    <SQL TYPE="TBL_FLD" TBL_ALIAS="" EETYPE="">D_CREA_DATE</SQL>
                <SQL TYPE="SQL"> = </SQL>
                <SQL TYPE="VAR" VALUE="SYS_BUSI_DATE">D_DATE</SQL>
				</CriFld>
		    </FIELD>	
		</FIELDS>
	</MAP_TBL>
	<CLAUSE BYUNITCODE="True">
		<SQL EETYPE="" TYPE="TBL_FLD" TBL_ALIAS="">C_TRX_STATUS</SQL>
		<SQL TYPE="SQL"> = 'M' ORDER BY </SQL>
		<SQL EETYPE="" TYPE="TBL_FLD">C_USER_ID</SQL>
	</CLAUSE>
</WIDGET> 
