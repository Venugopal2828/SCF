<?xml version="1.0" encoding="UTF-8"?>
<WIDGET NAME="top_buyer">
	<PATTERN>
		<TYPE>table</TYPE>
		<TITLE>Top Buyer Widget</TITLE>
		<RENDERCONTROL>div3</RENDERCONTROL>
		<AXIS/>
		<PERIOD Mapping_Field="D_CREA_DATE" Period_value="L">50</PERIOD>
		<ROWNUM>3</ROWNUM>
		<INTERVAL/>
	</PATTERN>
	<MAP_TBL>
		<TABLES>
			<TABLE ALIAS="" schema="%EXIMTRX%">GTEE_MASTER</TABLE>
		</TABLES>
		<FIELDS>
			<FIELD DESC="C_USER_ID" FIELD="C_USER_ID" TBL_ALIAS="" TYPE="" HIDDEN = "" DBFUNC=""></FIELD>
            <FIELD DESC="GTEE_CCY" FIELD="GTEE_CCY" TBL_ALIAS="" TYPE="" DBFUNC=""></FIELD>
            <FIELD DESC="GTEE_AMT" FIELD="GTEE_AMT" TBL_ALIAS="" TYPE="" DBFUNC="SUM">				
			<!--criteria field-->
				<GROUPBY>GTEE_CCY,C_USER_ID</GROUPBY>
			</FIELD>
			<FIELD DESC="GTEE_BAL" FIELD="GTEE_BAL" TBL_ALIAS="" TYPE="" DBFUNC="SUM">				
			<!--criteria field-->
				<GROUPBY>GTEE_CCY,C_USER_ID</GROUPBY>
			</FIELD>
		</FIELDS>
	</MAP_TBL>
	<CLAUSE BYUNITCODE="True">
		<SQL EETYPE="" TYPE="TBL_FLD" TBL_ALIAS="">C_TRX_STATUS</SQL>
		<SQL TYPE="SQL"> = 'M' ORDER BY </SQL>
		<SQL EETYPE="" TYPE="TBL_FLD">to_number(GTEE_AMT) DESC</SQL>
	</CLAUSE>
</WIDGET>
