<?xml version="1.0" encoding="UTF-8"?>
<WIDGET NAME="top_seller">
	<PATTERN>
		<TYPE>table</TYPE>
		<TITLE>Top Seller Widget</TITLE>
		<RENDERCONTROL>div4</RENDERCONTROL>
		<AXIS/>
		<PERIOD Mapping_Field="D_CREA_DATE" Period_value="L">20</PERIOD>
		<ROWNUM>3</ROWNUM>
		<INTERVAL/>
	</PATTERN>
	<MAP_TBL>
		<TABLES>
			<TABLE ALIAS="" schema="%EXIMTRX%">EPLC_EM_STL</TABLE>
		</TABLES>
		<FIELDS>			
            <FIELD DESC="AVAL_BY" FIELD="AVAL_BY" TBL_ALIAS="" TYPE="" HIDDEN = 'Y' DBFUNC=""></FIELD>
			
			<FIELD DESC="ADDIT_PRES_BK_CCY" FIELD="ADDIT_PRES_BK_CCY" TBL_ALIAS="" TYPE="" DBFUNC=""></FIELD>
            <FIELD DESC="AMT_TO_BENE_PRES_CCY" FIELD="AMT_TO_BENE_PRES_CCY" TBL_ALIAS="" TYPE="" DBFUNC="SUM">				
			<!--criteria field-->
				<GROUPBY>AVAL_BY,ADDIT_PRES_BK_CCY</GROUPBY>
			</FIELD>
		</FIELDS>
	</MAP_TBL>
	<CLAUSE BYUNITCODE="True">
		<SQL EETYPE="" TYPE="TBL_FLD" TBL_ALIAS="">C_TRX_STATUS</SQL>
		<SQL TYPE="SQL"> = 'M' ORDER BY </SQL>
		<SQL EETYPE="" TYPE="TBL_FLD">to_number(AMT_TO_BENE_PRES_CCY) DESC</SQL>
	</CLAUSE>
</WIDGET>