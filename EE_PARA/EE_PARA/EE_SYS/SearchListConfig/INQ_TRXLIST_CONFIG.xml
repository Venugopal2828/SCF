<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
	<GROP NAME="Transaction Records" DIV_ID="trx_list" ROWSPAGE="50">
				<COLS>
					<COL ID="1" NAME="Our Reference"/>
					<COL ID="2" NAME="Issue Date"/>
					<COL ID="3" NAME="Applicant Name"/>
					<COL ID="4" NAME="Bene Name"/>
					<COL ID="5" NAME="CCY"/>
					<COL ID="6" NAME="Amount"/>
					<COL ID="7" NAME="Unit Code"/>
					<COL ID="8" NAME="Trx Reference"/>
					<COL ID="9" NAME="Expiry Date"/>
					<COL ID="10" NAME="Closed Flag"/>
					<COL ID="11" NAME="Action"/>
				</COLS>
				<FUNCTION ID="F05030702318">
					<MAP_TBL>
						<TABLES>
							<TABLE ALIAS="" schema="%EXIMTRX%">GTEE_MASTER</TABLE>
						</TABLES>
						<FIELDS>
							<COL ID="1">
								<FIELD>C_MAIN_REF</FIELD>
							</COL>
							<COL ID="2">
								<FIELD TYPE="DATE">ISSUE_DT</FIELD>
							</COL>
							<COL ID="3">
								<FIELD>APPL_NM</FIELD>
							</COL>
							<COL ID="4">
								<FIELD>BENE_NM</FIELD>
							</COL>
							<COL ID="5">
								<FIELD>GTEE_CCY</FIELD>
							</COL>
							<COL ID="6">
								<FIELD TYPE="AMT">GTEE_AMT</FIELD>
							</COL>
							<COL ID="7">
								<FIELD>C_UNIT_CODE</FIELD>
							</COL>
							<COL ID="8">
								<FIELD>C_TRX_REF</FIELD>
							</COL>
							<COL ID="9">
								<FIELD>EXPIRY_DT</FIELD>
							</COL>
							<COL ID="10">
								<FIELD>CLS_FLG</FIELD>
							</COL>
							<COL ID="11">
								<!--TEXT>&lt;img src='../Images/doimage/forward.gif' style='cursor:hand'&gt;</TEXT-->
								<TEXT>ACTION_BUTTON</TEXT>
							</COL>
						</FIELDS>
					</MAP_TBL>
					<CLAUSE BYGLOBAL="False" BYUNITCODE="False">
						<SQL EETYPE="" TYPE="TBL_FLD">C_TRX_STATUS</SQL>
						<SQL TYPE="SQL"> = 'M' ORDER BY </SQL>
						<SQL EETYPE="" TYPE="TBL_FLD">C_MAIN_REF</SQL>
					</CLAUSE>
				</FUNCTION>
			</GROP>
	<GROP NAME="Supervisor Queue" DIV_ID="trx_list_LCRelease" ROWSPAGE="10">
		<COLS>
		<COL ID="1" NAME="Module"/>
		<COL ID="2" NAME="Reference Number"/>
		<COL ID="3" NAME="Currency"/>
		<COL ID="4" NAME="Amount"/>
		<COL ID="5" NAME="Appl/Drawer"/>
		<COL ID="6" NAME="Expiry Date"/>
		<COL ID="7" NAME="Function Name"/>
		</COLS>
		<FUNCTION ID="F05030702041">
			<MAP_TBL>
				<TABLES>
					<TABLE ALIAS="IPLC_LEDGER" schema="%EXIMTRX%">IPLC_LEDGER</TABLE>
				</TABLES>
				<FIELDS>
					<COL ID="1">
						<TEXT>IPLC</TEXT>
					</COL>
					<COL ID="2">
						<FIELD>C_MAIN_REF</FIELD>
					</COL>
					<COL ID="3">
						<FIELD>LC_CCY</FIELD>
					</COL>
					<COL ID="4">
						<FIELD TYPE="AMT" >LC_AMT</FIELD>
					</COL>
					<COL ID="5">
						<FIELD>APPL_NM</FIELD>
					</COL>
					<COL ID="6">
						<FIELD TYPE="DATE">EXPIRY_DT</FIELD>
					</COL>
					<COL ID="7">
						<FIELD>C_FUNC_SHORT_NAME</FIELD>
					</COL>
				</FIELDS>
			</MAP_TBL>
			<CLAUSE BYGLOBAL="False" BYUNITCODE="False">
				<SQL EETYPE="" TYPE="TBL_FLD">C_EVENT_STATUS</SQL>
				<SQL TYPE="SQL"> = 'P' ORDER BY </SQL>
				<SQL EETYPE="" TYPE="TBL_FLD">C_MAIN_REF</SQL>
			</CLAUSE>
		</FUNCTION>
		<FUNCTION ID="F05030701684">
			<MAP_TBL>
				<TABLES>
					<TABLE ALIAS="EXCO_LEDGER" schema="%EXIMTRX%">EXCO_LEDGER</TABLE>
				</TABLES>
				<FIELDS>
					<COL ID="1">
						<TEXT>EXCO</TEXT>
					</COL>
					<COL ID="2">
						<FIELD>C_MAIN_REF</FIELD>
					</COL>
					<COL ID="3">
						<FIELD>COLL_CCY</FIELD>
					</COL>
					<COL ID="4">
						<FIELD TYPE="AMT">COLL_TRX_CCY_AMT</FIELD>
					</COL>
					<COL ID="5">
						<FIELD>DRWR_NM</FIELD>
					</COL>
					<COL ID="6">
						<TEXT> </TEXT>
					</COL>
					<COL ID="7">
						<FIELD>C_FUNC_SHORT_NAME</FIELD>
					</COL>
				</FIELDS>
			</MAP_TBL>
			<CLAUSE BYGLOBAL="False" BYUNITCODE="False">
				<SQL EETYPE="" TYPE="TBL_FLD">C_EVENT_STATUS</SQL>
				<SQL TYPE="SQL"> = 'P' ORDER BY </SQL>
				<SQL EETYPE="" TYPE="TBL_FLD">C_MAIN_REF</SQL>
			</CLAUSE>
		</FUNCTION>
	</GROP>
	<GROP NAME="Fix Pending" DIV_ID="trx_list_FixPending" ROWSPAGE="10">
		<COLS>
		<COL ID="1" NAME="Reference Number"/>
		<COL ID="2" NAME="Expiry Date"/>
		<COL ID="3" NAME="Function Name"/>
		</COLS>
		<FUNCTION ID="F05030702040">
			<MAP_TBL>
				<TABLES>
					<TABLE ALIAS="IPLC_LEDGER" schema="%EXIMTRX%">IPLC_LEDGER</TABLE>
				</TABLES>
				<FIELDS>
					<COL ID="1">
						<FIELD>C_MAIN_REF</FIELD>
					</COL>
					<COL ID="2">
						<TEXT> The expiry date is : </TEXT>
						<FIELD TYPE="DATE">EXPIRY_DT</FIELD>
					</COL>
					<COL ID="3">
						<FIELD TYPE="DATE">C_FUNC_SHORT_NAME</FIELD>
					</COL>
				</FIELDS>
			</MAP_TBL>
			<CLAUSE BYGLOBAL="False" BYUNITCODE="True">
				<SQL EETYPE="" TYPE="TBL_FLD">C_EVENT_STATUS</SQL>
				<SQL TYPE="SQL"> = 'P' ORDER BY </SQL>
				<SQL EETYPE="" TYPE="TBL_FLD">C_MAIN_REF</SQL>
			</CLAUSE>
		</FUNCTION>
	</GROP>
	<GROP NAME="Incoming Failed SWIFTS" DIV_ID="swift_list" ROWSPAGE="10">
		<COLS>
		<COL ID="1" NAME="Date/Time"/>
		<COL ID="2" NAME="Message Type"/>
		<COL ID="3" NAME="Function Name"/>
		<COL ID="4" NAME="BIC_RefNumber"/>
		<COL ID="5" NAME="Info"/>
		</COLS>
		<FUNCTION ID="F05030702230">
			<MAP_TBL>
				<TABLES>
					<TABLE ALIAS="STP_IN_MSG_STO" schema="%EXIMSYS%">STP_IN_MSG_STO</TABLE>
				</TABLES>
				<FIELDS>
					<COL ID="1">
						<FIELD>T_PROC_TIME</FIELD>
					</COL>
					<COL ID="2">
						<FIELD>C_MESSAGE_TYPE</FIELD>
					</COL>
					<COL ID="3">
						<FIELD>C_FUNC_NAME</FIELD>
					</COL>
					<COL ID="4">
						<FIELD>C_ADBIC_LC</FIELD>
					</COL>
					<COL ID="5">
						<FIELD>C_PROC_INFO</FIELD>
					</COL>
				</FIELDS>
			</MAP_TBL>
			<CLAUSE BYGLOBAL="True" BYUNITCODE="False" >
				<SQL EETYPE="" TYPE="TBL_FLD">C_PROC_STATUS</SQL>
				<SQL TYPE="SQL"> = 'F'</SQL>
				<SQL TYPE="SQL"> ORDER BY </SQL>
				<SQL EETYPE="" TYPE="TBL_FLD">T_PROC_TIME</SQL>
			</CLAUSE>
		</FUNCTION>
	</GROP>
	<GROP NAME="Correspondence Inbox" DIV_ID="div_inbox">
		<COLS>
			<COL ID="1" NAME="Reference Number"/>
			<COL ID="2" NAME="Type"/>
		</COLS>
		<FUNCTION ID="F05030702004">
			<MAP_TBL>
				<TABLES>
					<TABLE ALIAS="COMM_LEDGER" schema="%EXIMTRX%">COMM_LEDGER</TABLE>
				</TABLES>
				<FIELDS>
					<COL ID="1">
						<FIELD>C_MAIN_REF</FIELD>
					</COL>
					<COL ID="2">
						<FIELD>C_FUNC_SHORT_NAME</FIELD>
					</COL>
				</FIELDS>
			</MAP_TBL>
			<CLAUSE BYGLOBAL="True" BYUNITCODE="True">
				<SQL EETYPE="" TYPE="TBL_FLD">C_EVENT_STATUS</SQL>
				<SQL TYPE="SQL"> = 'P' ORDER BY </SQL>
				<SQL EETYPE="" TYPE="TBL_FLD">C_MAIN_REF</SQL>
			</CLAUSE>
		</FUNCTION>
	</GROP>
</CONFIG>
