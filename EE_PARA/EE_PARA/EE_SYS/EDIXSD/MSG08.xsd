			<xs:element name="CurrentExpiryDate" type="xs:date" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="NewCreditCoverDetailsType">
		<xs:sequence>
			<xs:element name="NewCreditCoverAmt" type="NMax14.2Type"/>
			<xs:element name="NewExpiryDate" type="xs:date" minOccurs="0"/>
			<xs:element name="ValidFrom" type="xs:date" minOccurs="0"/>
			<xs:element name="LongCreditPeriodDays" type="NDef3Type" minOccurs="0"/>
			<xs:element name="Response" type="NMax3Type"/>
			<xs:element name="Reason" type="NMax3Type" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="OwnRiskNewCreditCoverType">
		<xs:sequence>
			<xs:element name="OwnRiskAmt" type="NMax14.2Type" minOccurs="0"/>
			<xs:element name="OwnRiskPerc" type="NDef3.4Type" minOccurs="0"/>
			<xs:element name="CreditCoverAmtCheck" type="NMax14.2Type"/>
		</xs:sequence>
	</xs:complexType>
</xs:schema>
