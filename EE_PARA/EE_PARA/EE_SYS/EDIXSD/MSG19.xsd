<?xml version="1.0" encoding="iso-8859-1"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns="urn:schemas-edifactoring-com:MSG19" targetNamespace="urn:schemas-edifactoring-com:MSG19" elementFormDefault="qualified">
	<xs:include schemaLocation="typeDef.xsd"/>
	<xs:element name="MSG19" type="MSG19Type"/>
	<xs:complexType name="MSG19Type">
		<xs:sequence>
			<xs:element name="MsgInfo" type="MsgInfoType"/>
			<xs:element name="EF" type="FType"/>
			<xs:element name="IF" type="FType"/>
			<xs:element name="MsgDate" type="xs:date"/>
			<xs:element name="DateTermination" type="xs:date"/>
			<xs:element name="Seller" type="SellerType"/>
			<xs:element name="TerminationReason" type="AMax350Type"/>
			<xs:element name="Instructions" type="AMax700Type" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="MsgInfoType">
		<xs:sequence>
