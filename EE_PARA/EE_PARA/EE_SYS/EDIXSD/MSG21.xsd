<?xml version="1.0" encoding="iso-8859-1"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns="urn:schemas-edifactoring-com:MSG21" targetNamespace="urn:schemas-edifactoring-com:MSG21" elementFormDefault="qualified">
