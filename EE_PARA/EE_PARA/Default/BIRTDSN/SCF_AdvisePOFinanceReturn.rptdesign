                                <expression name="expression" type="javascript">var acctNo='';&#13;
if(row["FA_BUSI_TYPE"]=='PF'){&#13;
acctNo= row["FA_COUNTER_ACC"];&#13;
} else if(row["FA_BUSI_TYPE"]=='RD' ||row["FA_BUSI_TYPE"]=='PO'){&#13;
acctNo = row["FA_ANCHOR_ACC"];&#13;
	}&#13;
this.value='We hereby inform you that we have done your PO Financing by crediting account under the name ' + row["FA_SEL_NM"] + ', account number ' + acctNo+ ', with the following details:';</expression>
                                <property name="dataType">string</property>
