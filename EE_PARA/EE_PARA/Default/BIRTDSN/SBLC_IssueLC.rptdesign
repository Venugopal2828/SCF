    <body>
        <table id="275">
            <property name="width">100%</property>
            <property name="dataSet">Data Set</property>
            <list-property name="boundDataColumns">
                <structure>
                    <property name="name">ISSUE_DT</property>
                    <expression name="expression">dataSetRow["ISSUE_DT"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">BENE_NM</property>
                    <expression name="expression">dataSetRow["BENE_NM"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">BENE_ADD1</property>
                    <expression name="expression">dataSetRow["BENE_ADD1"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">BENE_ADD2</property>
                    <expression name="expression">dataSetRow["BENE_ADD2"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">BENE_ADD3</property>
                    <expression name="expression">dataSetRow["BENE_ADD3"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">LC_AMT</property>
                    <expression name="expression">dataSetRow["LC_AMT"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">EXPIRY_DT</property>
                    <expression name="expression">dataSetRow["EXPIRY_DT"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">APPL_NM</property>
                    <expression name="expression">dataSetRow["APPL_NM"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">APPL_ADD1</property>
                    <expression name="expression">dataSetRow["APPL_ADD1"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">APPL_ADD2</property>
                    <expression name="expression">dataSetRow["APPL_ADD2"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">APPL_ADD3</property>
                    <expression name="expression">dataSetRow["APPL_ADD3"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Column Binding</property>
                    <expression name="expression">prefix = "We hereby establish our Irrevocable Standby Letter of Credit in your favor and authorize you to draw on us. for the account of ";
appl_nm = row["APPL_NM"];
suffix= "up to an aggregate amount of ";
lc_amt=row["LC_AMT"];
temp = prefix + appl_nm + suffix + lc_amt;
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para3</property>
                    <expression name="expression">prefix="Payment under this Letter of Credit is available by your draft at sight, drawn on ";
appl_nm=row["APPL_NM"];
appl_add1=row["APPL_ADD1"];
appl_add2=row["APPL_ADD2"];
appl_add3=row["APPL_ADD3"];
suffix=" to be accompanied by original beneficiary's statement purportedly signed by an authorized representative of Dane county, Planning &amp; Development Department certifying that.";
temp=prefix + appl_nm + ", "+ appl_add1 + ", "+appl_add2 + ", "+ appl_add3 + suffix;
this.value = temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para4</property>
                    <expression name="expression">prefix = "All drafts must be marked  \"Drawn under ";
bank_nm=row["APPL_NM"];
bank_add1=row["APPL_ADD1"];
bank_add2=row["APPL_ADD2"];
bank_add3=row["APPL_ADD3"];
C_MAIN_REF = dataSetRow["C_MAIN_REF"];
temp = prefix + bank_nm +  ", "+ bank_add1 + ", "+ bank_add2 + ", "+ bank_add3 + ", " + C_MAIN_REF + "\"";
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para5</property>
                    <expression name="expression">prefix="We agree with you to pay drafts drawn under and in compliance with the terms of this credit presented at our ";
bank_nm = row["BENE_NM"];
suffix=" office together with this Standby Letter of Credit and documents specified on or before the close of our business on ";
exp_date=row["EXPIRY_DT"];
temp = prefix + bank_nm + suffix + exp_date;
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para6</property>
                    <expression name="expression">prefix = "Negotiation is restricted to ";
bank_nm = row["BENE_NM"];
bank_add1 = row["BENE_ADD1"];
bank_add2 = row["BENE_ADD2"];
bank_add3 = row["BENE_ADD3"];
temp=prefix +  bank_nm +  ", " + bank_add1 +  ", " + bank_add2 +   ", " + bank_add3;
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para1</property>
                    <expression name="expression">prefix = "We hereby establish our Irrevocable Standby Letter of Credit in ";
C_MAIN_REF = dataSetRow["C_MAIN_REF"];
prefix1 = " your favor and authorize you to draw on us. for the account of ";
appl_nm = row["APPL_NM"];
suffix= " up to an aggregate amount of ";
lc_ccy=dataSetRow["LC_CCY"];
lc_amt=row["LC_AMT"];
temp = prefix + C_MAIN_REF + prefix1 + appl_nm + suffix + lc_ccy + lc_amt;
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">C_MAIN_REF</property>
                    <expression name="expression">dataSetRow["C_MAIN_REF"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para</property>
                    <expression name="expression">LC_CCY = dataSetRow["LC_CCY"];
LC_AMT = dataSetRow["LC_AMT"];
temp = LC_CCY + LC_AMT;
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
            </list-property>
