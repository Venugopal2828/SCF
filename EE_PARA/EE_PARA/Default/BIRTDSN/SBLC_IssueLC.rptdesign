                        <text id="413">
                            <property name="style">NewStyle54</property>
                            <property name="contentType">auto</property>
                            <text-property name="content"><![CDATA[In accordance with Dane County Ordinance 14.49(2)(1), this Letter of Credit is issued in connection with application for an erosion control or stormwater management permit.]]></text-property>
                        </text>
                    </cell>
