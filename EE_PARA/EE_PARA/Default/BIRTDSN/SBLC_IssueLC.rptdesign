                <row id="406">
                    <cell id="407">
                        <property name="colSpan">2</property>
                        <property name="rowSpan">1</property>
                        <text id="420">
                            <property name="style">NewStyle60</property>
                            <property name="contentType">auto</property>
                            <text-property name="content"><![CDATA[This Letter of Credit shall be deemed automatically extended without amendment for one year from the expiration date hereof or any expiration date unless at least sixty (60) days prior to any expiration date, we notify you in writing by certified mail or overnight courier service that we elect not to renew this Letter of Credit for such additional period.]]></text-property>
                        </text>
                    </cell>
                </row>
