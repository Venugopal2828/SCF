                <row id="382">
                    <cell id="383">
                        <property name="colSpan">2</property>
                        <property name="rowSpan">1</property>
                        <text id="415">
                            <property name="style">NewStyle53</property>
                            <property name="contentType">auto</property>
                            <text-property name="content"><![CDATA["Applicant has failed to complete proposed work in a manner sufficiently consistent with the approved plan, and the amount drawn is required to complete the unfinished or unsatisfactory work."]]></text-property>
                        </text>
                    </cell>
                </row>
                <row id="388">
                    <cell id="389">
                        <property name="colSpan">2</property>
                        <property name="rowSpan">1</property>
                        <text id="416">
                            <property name="style">NewStyle56</property>
                            <property name="contentType">auto</property>
                            <text-property name="content"><![CDATA[Partial drawings are allowed.]]></text-property>
                        </text>
                    </cell>
                </row>
                <row id="379">
                    <cell id="380">
                        <property name="colSpan">2</property>
                        <property name="rowSpan">1</property>
                        <text id="417">
                            <property name="style">NewStyle57</property>
                            <property name="contentType">auto</property>
                            <text-property name="content"><![CDATA[This Standby Letter of Credit sets forth in full the terms of our undertaking which shall not in any way be modified, amended, amplified or limited by reference to any document, instrument, or agreement, whether or not referred to herein.]]></text-property>
                        </text>
                    </cell>
                </row>
                <row id="3287">
                    <cell id="3288"/>
                    <cell id="3289"/>
                </row>
                <row id="391">
                    <cell id="392">
                        <property name="colSpan">2</property>
                        <property name="rowSpan">1</property>
                        <text id="418">
                            <property name="style">NewStyle58</property>
                            <property name="contentType">auto</property>
                            <text-property name="content"><![CDATA[This original Standby Letter of Credit must be submitted to us together with any drawings hereunder for our endorsement of any payments effected by us and/or for cancellation.]]></text-property>
                        </text>
                    </cell>
                </row>
