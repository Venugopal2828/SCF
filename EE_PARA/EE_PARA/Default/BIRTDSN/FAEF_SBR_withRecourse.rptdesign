                <cell id="182">
                    <text id="580">
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[□ Order
□ Invoice
□ Opinion accompanying the goods
□ The taking over certificate
□ Other.
It will take into account that all these documents are expressly stated in specific conditions supporting documents must be submitted along with the bill adherent subrogatorie]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="183">
                <cell id="184">
                    <text id="590">
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[- “To scroll through factoring of commercial contract / order is necessary to establish the right to make payments by money order or promissory note paid at maturity. If the parties approve of the promissory note, it will be presented to the bank with the shipping documents and will be endorsed in favor of the bank as security.”]]></text-property>
                    </text>
                </cell>
            </row>
