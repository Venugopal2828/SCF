                                            <structure>
                                                <property name="name">□ in cazul lipsei de disponibi</property>
                                                <expression name="expression">this.value=' □ in cazul lipsei de disponibil, sa inregistrati  la creante restante suma de '+dataSetRow["FA_DOC_CCY"]+  Total.sum(row._outer["FA_INV_LOAN_BAL"]) +', si sa ne informati corespunzator, deoarece pana la recuperarea creantelor restante, finantarea va fi stopata.'</expression>
                                                <property name="dataType">string</property>
                                            </structure>
                                        </list-property>
                                        <property name="resultSetColumn">□ in cazul lipsei de disponibi</property>
                                    </data>
                                </cell>
