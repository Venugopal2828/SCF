        <grid id="144">
            <property name="width">100%</property>
            <column id="145"/>
            <row id="146">
                <cell id="147">
                    <label id="152"/>
                </cell>
            </row>
            <row id="148">
                <cell id="149">
                    <label id="153">
                        <text-property name="text">Given the above, please:</text-property>
                    </label>
                </cell>
            </row>
            <row id="150">
                <cell id="151">
                    <label id="154">
                        <text-property name="text">&#13;
□ Ask your client emergency settlement agreement with the debtor to the dispute and submit its decision in order to properly inform the factoring company.</text-property>
                    </label>
                </cell>
            </row>
            <row id="158">
                <cell id="159">
                    <table id="224">
                        <property name="width">100%</property>
                        <property name="dataSet">Data Set</property>
                        <list-property name="boundDataColumns">
                            <structure>
                                <property name="name">FA_INDR_PMT_FLG</property>
                                <expression name="expression">dataSetRow["FA_INDR_PMT_FLG"]</expression>
                                <property name="dataType">string</property>
                            </structure>
                        </list-property>
                        <property name="pageBreakInterval">50</property>
                        <column id="231"/>
                        <header>
                            <row id="225">
                                <cell id="226">
                                    <label id="232">
                                        <list-property name="visibility">
                                            <structure>
                                                <property name="format">all</property>
                                                <expression name="valueExpr">row["FA_INDR_PMT_FLG"]!='1'</expression>
                                            </structure>
                                        </list-property>
                                        <text-property name="text">□ to request and track the repayment of amounts funded disputed invoices. Please transfer the amount earned in the current account in the collateral account to be able to operate reimbursement funding.</text-property>
                                    </label>
                                </cell>
                            </row>
                        </header>
                        <detail>
                            <row id="227">
                                <cell id="228">
                                    <data id="233">
                                        <list-property name="visibility">
                                            <structure>
                                                <property name="format">all</property>
                                                <expression name="valueExpr">true</expression>
                                            </structure>
                                        </list-property>
                                        <property name="resultSetColumn">FA_INDR_PMT_FLG</property>
                                    </data>
                                </cell>
                            </row>
                        </detail>
                        <footer>
                            <row id="229">
                                <cell id="230"/>
                            </row>
                        </footer>
                    </table>
                </cell>
            </row>
        </grid>
        <grid id="161">
            <property name="width">100%</property>
            <column id="162"/>
            <row id="163">
                <cell id="164">
                    <label id="169">
                        <text-property name="text">By solving this issue invoices to the debtor financing mentioned above will be stopped</text-property>
                    </label>
                </cell>
            </row>
            <row id="165">
                <cell id="166">
                    <label id="170"/>
                </cell>
            </row>
            <row id="167">
                <cell id="168">
                    <label id="171">
                        <text-property name="text">Please keep in mind the application of the factoring agreement, or right of recourse to the client by debiting the current account of it. in order to recover financing if the range of 10 days to the present, it does not reimburse the bank the amount due.&#13;
Sincerely,</text-property>
                    </label>
                </cell>
            </row>
            <row id="172">
                <cell id="173"/>
            </row>
            <row id="174">
                <cell id="175">
                    <label id="176">
                        <text-property name="text">Head of Department / Supervisor, Economist,</text-property>
                    </label>
                </cell>
            </row>
        </grid>
    </body>
