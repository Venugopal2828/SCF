                    <property name="name">APPL_ADD2</property>
                    <expression name="expression">dataSetRow["APPL_ADD2"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">APPL_ADD3</property>
                    <expression name="expression">dataSetRow["APPL_ADD3"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para</property>
                    <expression name="expression">first = "To: ";
appl_nm = dataSetRow["APPL_NM"];
appl_add1=dataSetRow["APPL_ADD1"];
appl_add2=dataSetRow["APPL_ADD2"];
appl_add3=dataSetRow["APPL_ADD3"];
temp = first + "\n" + appl_nm + "\n" + appl_add1 + "\n" + appl_add2 + "\n" + appl_add3 + "\n";
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para1</property>
                    <expression name="expression">first = "L/C Number: ";
second = dataSetRow["C_MAIN_REF"];
temp = first + "\n" + second + "\n\n";
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para2</property>
                    <expression name="expression">prefix = "We have debited your Account No. ";
suffix = dataSetRow["CHG_FLD_LOCAL_CUST_AC_NO"];
temp = prefix + suffix;
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para3</property>
                    <expression name="expression">first = "Value Date: ";
first_value = dataSetRow["ISSUE_DT"];
second = "L/C Amount: ";
second_value_ccy = dataSetRow["LC_CCY"];
second_value_amt = dataSetRow["LC_AMT"];
third = "Favoring: ";
third_value = dataSetRow["BENE_NM"];
temp = first + first_value + "\n" + second + second_value_ccy + second_value_amt + "\n"  + third + third_value + "\n";
this.value = temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para4</property>
                    <expression name="expression">prefix = "Total Debt Amount: ";
suffix = dataSetRow["CHG_LOCAL_COLLECT_CHG_TOTAL"];
temp = prefix + "\n" + "USD" + suffix + "\n";
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">CHG_FLD_COMM_DESC_1</property>
                    <expression name="expression">dataSetRow["CHG_FLD_COMM_DESC_1"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">CHG_FLD_COMM_DESC_2</property>
                    <expression name="expression">dataSetRow["CHG_FLD_COMM_DESC_2"]</expression>
