        <oda-data-set extensionID="org.eclipse.datatools.enablement.oda.xml.dataSet" name="Data Set" id="4804">
            <property name="nullsOrdering">nulls lowest</property>
            <list-property name="computedColumns">
                <structure>
                    <property name="name">CustomerName</property>
                    <expression name="expression">row["CNPT_ID"]+" -- "+row["CNPT_SWADD"];</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">TrxCurrency</property>
                    <expression name="expression">if(row["TRX_CCY"]=="CNY"){&#13;
    "CNH";&#13;
}else{&#13;
    row["TRX_CCY"];&#13;
}</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Folder</property>
                    <expression name="expression">row["FOLDER"]+" -- "+row["KONDOR_FOLDER"];</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">TicketTitle</property>
                    <expression name="expression">if(row["DEAL_ACTION"] != "New"){&#13;
  row["DEAL_ACTION"]+" Money Market Dealing Ticket";&#13;
}else{&#13;
  " MM Dealing Ticket";&#13;
}</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">OverAccount</property>
                    <expression name="expression">if(row["OVER_AC_FLG"] == "Yes"){&#13;
  "*** Over Account ***";&#13;
}else if(row["OVER_AC_FLG"] == "No"){&#13;
  "";&#13;
}</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">TtlNostroAmt</property>
                    <expression name="expression">(row["OLD_AMT"]+row["OLD_INT_AMT"])-row["TRX_AMT"]</expression>
                    <property name="dataType">decimal</property>
                </structure>
                <structure>
                    <property name="name">Deal Type</property>
                    <expression name="expression">if(row["DEAL_TP"] == "IP"){&#13;
	"Lending Out";&#13;
}else{&#13;
	"Borrow In";&#13;
}</expression>
                    <property name="dataType">string</property>
                </structure>
            </list-property>
