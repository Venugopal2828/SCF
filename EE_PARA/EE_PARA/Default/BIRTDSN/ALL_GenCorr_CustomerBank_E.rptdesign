                    <table id="10">
                        <property name="fontFamily">"Futura Book"</property>
                        <property name="fontSize">11pt</property>
                        <property name="width">100%</property>
                        <property name="dataSet">Data Set</property>
                        <list-property name="boundDataColumns">
                            <structure>
                                <property name="name">TEMP_CUST_INSTR</property>
                                <expression name="expression">dataSetRow["TEMP_CUST_INSTR"]</expression>
