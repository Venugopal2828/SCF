                                <property name="dataType">string</property>
                            </structure>
                            <structure>
                                <property name="name">TEMP_CORR_INSTR</property>
                                <expression name="expression">var temp="";
if(dataSetRow["CORR_CUST_BANK"]=="Customer" ){
temp = dataSetRow["TEMP_CUST_CRSPD"];
}
else if(dataSetRow["CORR_CUST_BANK"]=="Bank"){
temp = dataSetRow["TEMP_CORR_CRSPD"];
}
this.text=temp;</expression>
                                <property name="dataType">string</property>
                            </structure>
                            <structure>
                                <property name="name">TEMP_CUST_CRSPD</property>
                                <expression name="expression">temp="";
if(dataSetRow["CORR_CUST_BANK"]=="Customer" ){
temp = dataSetRow["TEMP_CUST_CRSPD"];
}
else if(dataSetRow["CORR_CUST_BANK"]=="Bank"){
temp = dataSetRow["TEMP_CORR_CRSPD"];
}
this.text=temp;</expression>
                                <property name="dataType">string</property>
                            </structure>
