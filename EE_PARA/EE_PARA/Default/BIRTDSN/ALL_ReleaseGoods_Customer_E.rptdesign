                <structure>
                    <property name="name">TRAN_DOC_TYPE</property>
                    <expression name="expression">temp="";
if (dataSetRow["TRAN_DOC_TYPE"]=="CMR"){
temp="CMR number";
}
if (dataSetRow["TRAN_DOC_TYPE"]=="Air Waybill"){
temp="Air Waybill number";
}
if (dataSetRow["TRAN_DOC_TYPE"]=="Other"){
temp="Transport document number";
}
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Column Binding</property>
                    <expression name="expression">temp="";
if(dataSetRow["SIGNATURE1"]==null &amp;&amp; dataSetRow["SIGNATURE2"]==null){
temp="Advice valid without signature";
}
if (dataSetRow["SIGNATURE1"]==null &amp;&amp; dataSetRow["SIGNATURE2"]!=null){
temp=dataSetRow["SIGNATURE2"];
}
if (dataSetRow["SIGNATURE1"] !=null &amp;&amp;dataSetRow["SIGNATURE2"]==null){
temp=dataSetRow["SIGNATURE1"];
}
this.value=temp;</expression>
                    <property name="dataType">any</property>
                </structure>
