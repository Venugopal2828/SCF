            </row>
            <row id="181">
                <cell id="182">
                    <label id="311">
                        <text-property name="text">As the above, So:
  Your client requires emergency settlement agreement with the debtor to the dispute and submit its decision in order to properly inform the factoring company.</text-property>
                    </label>
                </cell>
            </row>
            <row id="183">
                <cell id="184"/>
            </row>
            <row id="207">
                <cell id="208">
                    <table id="277">
                        <property name="width">100%</property>
                        <property name="dataSet">Data Set</property>
                        <list-property name="visibility">
                            <structure>
                                <property name="format">all</property>
                                <expression name="valueExpr">row["FA_INDR_PMT_FLG"]!='1'</expression>
                            </structure>
                        </list-property>
                        <list-property name="boundDataColumns">
                            <structure>
                                <property name="name">FA_INDR_PMT_FLG</property>
                                <expression name="expression">dataSetRow["FA_INDR_PMT_FLG"]</expression>
                                <property name="dataType">string</property>
                            </structure>
                        </list-property>
                        <column id="284"/>
                        <header>
                            <row id="278">
                                <cell id="279">
                                    <label id="285">
                                        <text-property name="text">   to request and track the repayment of amounts funded disputed invoices, collected directly in
client. Please transfer the amount earned in the current account in the collateral account to be able to
operate reimbursement funding. </text-property>
                                    </label>
                                </cell>
                            </row>
                        </header>
                        <detail>
                            <row id="280">
                                <cell id="281">
                                    <data id="287">
                                        <list-property name="visibility">
                                            <structure>
                                                <property name="format">all</property>
                                                <expression name="valueExpr">true</expression>
                                            </structure>
                                        </list-property>
                                        <property name="resultSetColumn">FA_INDR_PMT_FLG</property>
                                    </data>
                                </cell>
                            </row>
                        </detail>
                        <footer>
                            <row id="282">
                                <cell id="283"/>
                            </row>
                        </footer>
                    </table>
                </cell>
            </row>
            <row id="210">
                <cell id="211">
                    <label id="286">
                        <text-property name="text">By solving this issue invoices to the debtor financing mentioned above will be stopped. 

Regards,

Sef departament/Supervizor,	                                                                        Economist,</text-property>
                    </label>
                </cell>
            </row>
        </grid>
    </body>
