                    <expression name="expression" type="javascript">var amt = 0;&#13;
if (row["STL_INSTR_FLG"]=='Deduct Charges from Proceeds'){&#13;
 amt = BirtMath.subtract(BirtMath.subtract(BirtMath.subtract(dataSetRow["FA_FIN_AMT"], dataSetRow["TEMP_CHG_AMT1"]), dataSetRow["INT_AMT"]), dataSetRow["TEMP_CHG_AMT2"]);&#13;
} else if (row["STL_INSTR_FLG"]=='Take Charges Separately'){&#13;
 amt = BirtMath.subtract(dataSetRow["FA_FIN_AMT"], dataSetRow["INT_AMT"]);&#13;
} &#13;
