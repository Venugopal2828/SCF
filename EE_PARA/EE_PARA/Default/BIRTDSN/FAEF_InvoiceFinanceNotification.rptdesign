                    <expression name="expression" type="javascript">var acNo='';&#13;
if (row["STL_INSTR_FLG"]=='Deduct Charges from Proceeds'){&#13;
acNo= row["CPYT_CR_AC"];&#13;
} else if (row["STL_INSTR_FLG"]=='Take Charges Separately'){&#13;
acNo= row["CHG_FLD_LOCAL_CUST_AC_NO"];&#13;
} &#13;
this.value = 'Kami telah mendebit rekening Saudara Nomor '+ acNo + ' untuk biaya-biaya terkait Invoice Financing \nsebagai berikut:';</expression>
