                <structure>
                    <property name="name">BAHASA1</property>
                    <expression name="expression" type="javascript">var acctNm='';&#13;
var acctNo='';&#13;
var bkNm='';&#13;
if(row["CPYT_CR_AC_TYPE"]=='CUSTOMER'){&#13;
acctNm= row["CPYT_ASSGN_NM"];&#13;
acctNo= row["CPYT_CR_AC"];&#13;
bkNm = 'Mandiri';&#13;
} else if(row["CPYT_CR_AC_TYPE"]=='NOSTRO' || row["CPYT_CR_AC_TYPE"]=='VOSTRO'){&#13;
if( row["CPYT_PAY_ADV_MSG"] =='MT103'){&#13;
		 acctNm = row["X103_BENECU_NM_59A"];&#13;
	     acctNo = row["X103_BENECUACNO59A"].substr(1, row["X103_BENECUACNO59A"].length - 1);&#13;
	     bkNm = row["X103_ADV_BKNM_B2"];&#13;
	}else{&#13;
	     acctNm = row["CPYT_ASSGN_NM"];&#13;
	     acctNo = row["X202_BENEBKACNO58A"].substr(1, row["X202_BENEBKACNO58A"].length - 1);&#13;
	     bkNm = row["X202_BENE_BKNM_58A"];&#13;
	}&#13;
} else if(row["CPYT_CR_AC_TYPE"]=='RTGS'){&#13;
acctNm= row["RTGS_BENE_NM"] ;&#13;
acctNo=row["RTGS_CR_AC"];&#13;
bkNm=row["RTGS_BK_NM"] ;&#13;
} else if(row["CPYT_CR_AC_TYPE"]=='SKN'){&#13;
acctNm= row["SKN_BENE_NM"] ;&#13;
acctNo=row["SKN_CR_AC"];&#13;
bkNm=row["SKN_BK_NM"] ;&#13;
}&#13;
&#13;
this.value='Bersama ini kami informasikan bahwa kami telah mencairkan Invoice Financing Saudara dengan mengkredit rekening atas nama ' + acctNm + ', nomor rekening ' + acctNo+ ', pada Bank '+bkNm +' dengan rincian sebagai berikut:';</expression>
                    <property name="dataType">string</property>
