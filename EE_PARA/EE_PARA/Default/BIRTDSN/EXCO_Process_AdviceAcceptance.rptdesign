                        <column id="121">
                            <property name="width">1.975in</property>
                        </column>
                        <header>
                            <row id="78">
                                <cell id="79">
                                    <label id="122">
                                        <property name="textAlign">left</property>
                                        <text-property name="text">Collection No.:</text-property>
                                    </label>
                                </cell>
                                <cell id="80">
                                    <data id="129">
                                        <property name="textAlign">left</property>
                                        <property name="resultSetColumn">C_MAIN_REF</property>
                                    </data>
                                </cell>
                                <cell id="81">
                                    <label id="128">
                                        <property name="textAlign">left</property>
                                        <text-property name="text">Date:</text-property>
                                    </label>
                                </cell>
                                <cell id="82">
                                    <property name="textAlign">left</property>
                                    <data id="130">
                                        <property name="resultSetColumn">REMT_DT</property>
                                    </data>
                                </cell>
                            </row>
                        </header>
                        <detail>
                            <row id="83">
                                <cell id="84">
                                    <label id="123">
                                        <text-property name="text">Drawee:</text-property>
                                    </label>
                                </cell>
                                <cell id="85">
                                    <data id="131">
                                        <property name="resultSetColumn">DRWE_NM</property>
                                    </data>
                                </cell>
                                <cell id="86"/>
                                <cell id="87"/>
                            </row>
                            <row id="88">
                                <cell id="89">
                                    <label id="124">
                                        <text-property name="text">Collecting Bank:</text-property>
                                    </label>
                                </cell>
                                <cell id="90">
                                    <text id="132">
                                        <property name="contentType">html</property>
                                        <text-property name="content"><![CDATA[<VALUE-OF>row["COLL_BK_NM"]+'&amp;nbsp;'+row["COLL_BK_ADD1"]+'&amp;nbsp;'+row["COLL_BK_ADD2"]+'&amp;nbsp;'+row["COLL_BK_ADD3"]</VALUE-OF>]]></text-property>
                                    </text>
                                </cell>
                                <cell id="91"/>
                                <cell id="92"/>
                            </row>
                            <row id="93">
                                <cell id="94">
                                    <label id="125">
                                        <text-property name="text">Collection Amount:</text-property>
                                    </label>
                                </cell>
                                <cell id="95">
                                    <text id="133">
                                        <property name="contentType">html</property>
                                        <text-property name="content"><![CDATA[<VALUE-OF>row["COLL_CCY"]+'&amp;nbsp;'+row["COLL_TRX_CCY_AMT"]</VALUE-OF>]]></text-property>
                                    </text>
                                </cell>
                                <cell id="96"/>
                                <cell id="97"/>
                            </row>
                            <row id="98">
                                <cell id="99">
                                    <label id="126">
                                        <text-property name="text">Tenor:</text-property>
                                    </label>
                                </cell>
                                <cell id="100">
                                    <text id="134">
                                        <property name="contentType">html</property>
                                        <text-property name="content"><![CDATA[<VALUE-OF>row["TENOR_DAYS"]+'&amp;nbsp;'+row["DAY_MON_FLG"]+'&amp;nbsp;'+row["TENOR_TYPE"]</VALUE-OF>]]></text-property>
                                    </text>
                                </cell>
                                <cell id="101"/>
                                <cell id="102"/>
                            </row>
                            <row id="103">
                                <cell id="104">
                                    <label id="127">
                                        <text-property name="text">Maturity Date:</text-property>
                                    </label>
                                </cell>
                                <cell id="105">
                                    <data id="135">
                                        <property name="resultSetColumn">DUE_DT</property>
                                    </data>
                                </cell>
                                <cell id="106"/>
                                <cell id="107"/>
                            </row>
                        </detail>
                    </table>
                </cell>
            </row>
            <row id="136">
                <cell id="137"/>
                <cell id="138"/>
                <cell id="139"/>
            </row>
            <row id="140">
                <cell id="141">
                    <property name="colSpan">3</property>
                    <property name="rowSpan">1</property>
                    <text id="144">
                        <property name="contentType">html</property>
                        <text-property name="content"><![CDATA[<VALUE-OF>'Please be advised that the above documents has been accepted by Drawee as Drawee’s Bank MTXXX dated'</VALUE-OF>
<VALUE-OF>'&amp;nbsp;'</VALUE-OF>
<VALUE-OF>row["ACPT_DT"]</VALUE-OF>
<VALUE-OF>'&amp;nbsp;for&amp;nbsp;'</VALUE-OF>
<VALUE-OF>'&amp;nbsp;to mature&amp;nbsp;'</VALUE-OF>
<VALUE-OF>row["DUE_DT"]</VALUE-OF>
<VALUE-OF>'&amp;nbsp;(see copy).'</VALUE-OF>]]></text-property>
                    </text>
                </cell>
            </row>
        </grid>
