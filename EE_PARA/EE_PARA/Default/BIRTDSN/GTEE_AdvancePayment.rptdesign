            <row id="150">
                <cell id="151">
                    <label id="43">
                        <property name="fontFamily">"Calibri"</property>
                        <text-property name="text">Contract:</text-property>
                    </label>
                </cell>
                <cell id="152">
                    <text id="205">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="textAlign">left</property>
                        <property name="contentType">html</property>
                        <text-property name="content"><![CDATA[No <VALUE-OF>row["X798_20E_REL"]</VALUE-OF> dated <VALUE-OF>if(row["X798_31R_REF_DT1"]!=""&amp;&amp;row["X798_31R_REF_DT1"]!=null){
this.value = row["X798_31R_REF_DT1"];
}else if(row["X798_31R_REF_DT2"]!=""&amp;&amp;row["X798_31R_REF_DT2"]!=null){
this.value = row["X798_31R_REF_DT2"];
}</VALUE-OF>, for the supply of <VALUE-OF>row["X798_72C_C2B_INFO"]</VALUE-OF>.]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="153">
                <cell id="154">
                    <label id="45">
                        <property name="fontFamily">"Calibri"</property>
                        <text-property name="text">Guarantee amount:</text-property>
                    </label>
                </cell>
                <cell id="155">
                    <text id="290">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">html</property>
                        <text-property name="content"><![CDATA[<VALUE-OF>row["GTEE_CCY"]</VALUE-OF><VALUE-OF>row["GTEE_AMT"]</VALUE-OF>]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="156">
                <cell id="157">
                    <label id="48">
                        <property name="fontFamily">"Calibri"</property>
                        <text-property name="text">Expiry Date:</text-property>
                    </label>
                </cell>
                <cell id="158">
                    <data id="207">
                        <property name="fontFamily">"Calibri"</property>
                        <structure name="dateTimeFormat">
                            <property name="category">Custom</property>
                            <property name="pattern">dd/MM/yyyy</property>
                        </structure>
                        <property name="textAlign">left</property>
                        <property name="dataSet">Data Set</property>
                        <list-property name="boundDataColumns">
                            <structure>
                                <property name="name">EXPIRY_DT</property>
                                <text-property name="displayName">EXPIRY_DT</text-property>
                                <expression name="expression" type="javascript">if(dataSetRow["EXPIRY_DT"]!=""&amp;&amp;dataSetRow["EXPIRY_DT"]!=null){&#13;
this.value = dataSetRow["EXPIRY_DT"];&#13;
}else if(dataSetRow["X798_31S_DOC_DATE"]!=""&amp;&amp;dataSetRow["X798_31S_DOC_DATE"]!=null){&#13;
this.value = dataSetRow["X798_31S_DOC_DATE"];&#13;
}</expression>
                                <property name="dataType">string</property>
                            </structure>
                        </list-property>
                        <property name="resultSetColumn">EXPIRY_DT</property>
                    </data>
                </cell>
            </row>
            <row id="159">
                <cell id="160">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="208">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[We have been informed that the Applicant has entered into the Contract with you.  ]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="162">
                <cell id="163">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="259">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">html</property>
                        <text-property name="content"><![CDATA[Furthermore, we understand that, according to the conditions of the Contract, an advance payment in the amount of <VALUE-OF>row["GTEE_CCY"]</VALUE-OF><VALUE-OF>row["GTEE_AMT"]</VALUE-OF>. representing <VALUE-OF>row["X798_37J_GURE_VALUE_PERCENT"]</VALUE-OF>% of the amount of the Contract,<VALUE-OF>row["X798_71F_TOTAL_CONTR_CCY"]</VALUE-OF><VALUE-OF>row["X798_71F_TOTAL_CONTR_AMT"]</VALUE-OF> is to be made against an advance payment guarantee.]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="165">
                <cell id="166">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="210">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">html</property>
                        <text-property name="content"><![CDATA[As guarantor we, BANK A, hereby irrevocably undertake to pay you any amount not exceeding in total the Guarantee Amount upon receipt by us of your demand in writing including your statement in what respect the Applicant is in breach of its obliga-tion(s) under the Contract.]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="168">
                <cell id="169">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="211">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[It is a condition for any claim and payment under this guarantee to be made that the ad-vance payment referred to above must have been received by the Applicant. A demand under this guarantee must include a statement by your bank, stating that the said bank has paid the advance payment referred to above to the Applicant’s account number (ac-count number in IBAN-format) maintained with (name of account-holding bank), referring to this guarantee.]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="171">
                <cell id="172">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="212">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[This guarantee is not assignable or transferable without our and Applicant’s prior written consent.]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="174">
                <cell id="175">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="213">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[Any demand for payment under this guarantee must be received by us in writing by reg-istered mail at this office on or before the Expiry Date. The original of this guarantee shall be returned to us upon expiry. However, after our payment of the whole of the Guarantee Amount or the Expiry Date, whichever comes first, this guarantee will become null and void, whether returned to us or not.]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="177">
                <cell id="178">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="214">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[For the purpose of identification, your request for payment in writing must be presented to us through the intermediary of a first rate bank confirming that the signatures thereon are legally binding upon you.]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="180">
                <cell id="181">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="215">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[Your claim is also acceptable if transmitted to us in full by duly encoded SWIFT through a first rate bank confirming that your original claim has been sent to us by registered airmail and that the signatures thereon are legally binding upon you.  ]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="183">
                <cell id="184">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="216">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[Your claim will be considered as having been made once we are in possession of the written request for payment or SWIFT to this effect at our address. If claimed by SWIFT, the original written claim must be submitted to us.]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="186">
                <cell id="187">
                    <label id="53">
                        <property name="fontFamily">"Calibri"</property>
                        <text-property name="text">SWIFT address:</text-property>
                    </label>
                </cell>
                <cell id="188">
                    <label id="262">
                        <property name="fontFamily">"Calibri"</property>
                        <text-property name="text">PTSABMABXXX</text-property>
                    </label>
                </cell>
            </row>
            <row id="189">
                <cell id="190">
                    <property name="colSpan">2</property>
                    <property name="rowSpan">1</property>
                    <text id="218">
                        <property name="fontFamily">"Calibri"</property>
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[This guarantee shall be governed by and construed in accordance with Swedish law and shall be subject to the jurisdiction of Swedish courts with Stockholm City Court as the court of first instance.

This guarantee is subject to the Uniform Rules for Demand Guarantees (URDG), 2010 revision, ICC Publication No. 758. 
]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="192">
                <cell id="193">
                    <label id="263">
                        <property name="fontFamily">"Calibri"</property>
                        <text-property name="text">NEW YORK</text-property>
                    </label>
