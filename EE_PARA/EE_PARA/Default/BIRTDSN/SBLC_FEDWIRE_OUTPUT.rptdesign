    <body>
        <table id="305">
            <property name="width">100%</property>
            <property name="dataSet">Data Set</property>
            <list-property name="boundDataColumns">
                <structure>
                    <property name="name">APPL_ADD2</property>
                    <expression name="expression">dataSetRow["APPL_ADD2"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">APPL_NM</property>
                    <expression name="expression">dataSetRow["APPL_NM"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">BENE_ADD1</property>
                    <expression name="expression">dataSetRow["BENE_ADD1"]</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para</property>
                    <expression name="expression">prefix = dataSetRow["APPL_ID"];
suffix = "Branch Number";
temp = prefix + "\n" + suffix;
this.value = temp;</expression>
                    <property name="dataType">any</property>
                </structure>
                <structure>
                    <property name="name">Para1</property>
                    <expression name="expression">prefix = dataSetRow["CPYT_DR_VAL_DATE"];
suffix = "DATE";
temp = prefix + "\n" + suffix;
this.value = temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para2</property>
                    <expression name="expression">prefix = "$" + dataSetRow["CPYT_DR_AMT_DRCCY"];
suffix = "FEE";
temp = prefix + "\n" +suffix;
this.value=temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para3</property>
                    <expression name="expression">prefix = "$" + dataSetRow["CPYT_CR_AMT_CRCCY"];
suffix = "WIRE AMOUNT";
temp = prefix + "\n" + suffix;
this.value= temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para4</property>
                    <expression name="expression">prefix = dataSetRow["APPL_NM"];
suffix = "ORIGINATOR’S NAME";
temp = prefix +"\n"+suffix;
this.value = temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para5</property>
                    <expression name="expression">appl_add1 = dataSetRow["APPL_ADD1"];
appl_add2 = dataSetRow["APPL_ADD2"];
appl_add3 = dataSetRow["APPL_ADD3"];
suffix = "ORIGINATOR’S ADDRESS (Street/City/State/Zip) *** NO P.O. Box’s, this must be a physical IRS address ***";
temp = appl_add1 +", "+ appl_add2 +", "+ appl_add3 + "\n"+ suffix;
this.value = temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para6</property>
                    <expression name="expression">prefix = dataSetRow["BENE_NM"];
suffix = "BENEFICIARY’S NAME";
temp = prefix + "\n"+ suffix;
this.value = temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
                    <property name="name">Para7</property>
                    <expression name="expression">bene_add1=dataSetRow["BENE_ADD1"];
bene_add2=dataSetRow["BENE_ADD2"];
bene_add3= dataSetRow["BENE_ADD3"];
suffix="BENEFICIARY’S ADDRESS (Street/City/State/Zip)";
temp = bene_add1 + ", "+ bene_add2 + ", "+ bene_add3 + "\n"+ suffix;
this.value = temp;</expression>
                    <property name="dataType">string</property>
                </structure>
                <structure>
