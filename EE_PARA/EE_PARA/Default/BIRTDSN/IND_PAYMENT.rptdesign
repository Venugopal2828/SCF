                    <text id="263">
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[□ sa transferati deindata sumele incasate in contul curent in contul „Alte depozite colaterale-sume pentru incasare creante comerciale creditate” pentru a fi in masura sa operam rambursarea finantarii acordate]]></text-property>
                    </text>
                </cell>
            </row>
            <row id="261">
                <cell id="262">
                    <text-data id="264">
                        <property name="color">#FF8000</property>
                        <expression name="valueExpr">this.value=' □ in cazul lipsei de disponibil, sa inregistrati  la creante restante suma de '+params["FA_DOC_CCY"]+params["TTL_LOAN_BAL?????"]+', si sa ne informati corespunzator, deoarece pana la recuperarea creantelor restante, finantarea va fi stopata.'</expression>
                        <property name="contentType">html</property>
                    </text-data>
                </cell>
