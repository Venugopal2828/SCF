                        <expression name="valueExpr">this.value='Intrucat  partenerul '+params["FA_BUYER_NM"]+' a efectuat  direct in contul curent  al  '+params["FA_SEL_NM"]+' plata  facturii/facturilor mai sus mentionate, va rugam :'</expression>
