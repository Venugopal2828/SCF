            <xml-property name="queryText"><![CDATA[select FA_ANCHOR_NM,
       FA_CNTR_DOC_NO,
       FA_COUNTER_NM,
       FA_ANCHOR_CCY,
       FA_ANCHOR_AMT,
       FA_TTL_INV_NO,
       FA_TTL_INV_AMT,
       FA_TTL_INV_BAL,
       AMT_AVAL_FOR_FUNDING,
       FA_TTL_INV_LOAN_AMT,
       FA_TTL_LOAN_BAL,
       FA_BUSI_TYPE,
       FA_BUSI_FUNC
  FROM EXIMTRX.FADA_MASTER
 WHERE FA_BUSI_TYPE = 'SF'
       AND FA_BUSI_FUNC <> '2'
]]></xml-property>
