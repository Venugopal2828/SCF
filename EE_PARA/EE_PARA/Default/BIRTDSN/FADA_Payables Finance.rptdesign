            <method name="beforeOpen"><![CDATA[importPackage(Packages.com.cs.mizuho.birt);
var sql = this.queryText;

if(params["Anchor Customer Name"].value != ""&amp;&amp;params["Anchor Customer Name"].value != null){
        sql=sql+ " AND LOWER(FA_ANCHOR_NM) LIKE LOWER('%"+ params["Anchor Customer Name"]+"%')";   
}

if(params["Agreement Document No"].value != ""&amp;&amp;params["Agreement Document No"].value != null){
        sql=sql+ " AND FA_CNTR_DOC_NO = '"+ params["Agreement Document No"]+"'";  
} 

sql=sql+" ORDER BY FA_ANCHOR_NM,FA_ANCHOR_CCY";
sql = CSBirtTool.replaceSQLSchema(sql);
CSBirtTool.writeLog(sql);
this.queryText = sql;

]]></method>
