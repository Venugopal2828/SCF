            <row id="227">
                <cell id="228">
                    <data id="258">
                        <property name="dataSet">Data Set</property>
                        <list-property name="boundDataColumns">
                            <structure>
                                <property name="name">Urmare solicitarii</property>
                                <expression name="expression" type="javascript">this.value='Following application '+dataSetRow["FA_SEL_NM"]+', scroll factoring in external system, the commercial contract / order to '+dataSetRow["FA_BUYER_NM"]+', Please be aware that it has been communicated by external companies factoring'+dataSetRow["FA_IF_NM"]+', strongly limit the risk of loss coverage: '+dataSetRow["FA_LMT_CCY"]+dataSetRow["FA_LMT_AMT"]+'.'</expression>
                                <property name="dataType">string</property>
                            </structure>
                        </list-property>
                        <property name="resultSetColumn">Urmare solicitarii</property>
                    </data>
                </cell>
            </row>
            <row id="229">
                <cell id="230">
                    <label id="237"/>
                </cell>
            </row>
            <row id="231">
                <cell id="232">
                    <data id="259">
                        <property name="dataSet">Data Set</property>
                        <list-property name="boundDataColumns">
                            <structure>
                                <property name="name">Va rugam sa intocmiti documentele</property>
                                <expression name="expression" type="javascript">this.value='Please drawing up the documents necessary for the development of factoring operations, has ended the relationship with the borrower specific conditions '+dataSetRow["FA_BUYER_NM"]+' and we submit, by signing a copy thereof. '</expression>
                                <property name="dataType">string</property>
                            </structure>
                        </list-property>
                        <property name="resultSetColumn">Va rugam sa intocmiti documentele</property>
                    </data>
                </cell>
            </row>
            <row id="233">
                <cell id="234">
                    <data id="260">
                        <property name="dataSet">Data Set</property>
                        <list-property name="boundDataColumns">
                            <structure>
                                <property name="name">Va rugam totodata sa inregistrat</property>
                                <expression name="expression" type="javascript">this.value='Please register in SIBCOR reference also ETL relationship '+dataSetRow["C_MAIN_REF"]+' account opening and have available the type of operations and factoring of accounts derived and our factoring account number opened.'</expression>
                                <property name="dataType">string</property>
                            </structure>
                        </list-property>
                        <property name="resultSetColumn">Va rugam totodata sa inregistrat</property>
                    </data>
                </cell>
            </row>
            <row id="239">
                <cell id="240">
                    <label id="246"/>
                </cell>
            </row>
            <row id="242">
                <cell id="243">
                    <data id="261">
                        <property name="dataSet">Data Set</property>
                        <list-property name="boundDataColumns">
                            <structure>
                                <property name="name">De asemenea,</property>
                                <expression name="expression" type="javascript">this.value='It will also resolve the debtor Annex approved notification letter, which must be issued by '+dataSetRow["FA_SEL_NM"]+', wear header and authorized signature of the client (authenticated by branch ABC Bank), dated at / after signing specific conditions and to submit Factoring Department of ABC Bank Central (original) to be sent to the debtor: '+dataSetRow["FA_BUYER_NM"]+'. For efficiency, the customer can send the fax notification letter following foreign partner to countersign it and send it back by fax.'</expression>
                                <property name="dataType">string</property>
                            </structure>
                        </list-property>
                        <property name="resultSetColumn">De asemenea,</property>
                    </data>
                </cell>
            </row>
            <row id="244">
                <cell id="245">
                    <data id="262">
                        <property name="dataSet">Data Set</property>
                        <list-property name="boundDataColumns">
                            <structure>
                                <property name="name">Anexam totodata,</property>
                                <expression name="expression" type="javascript">this.value='We attach also, mention subrogatorie which necessarily must be stated on all invoices (originals and copies) by '+dataSetRow["FA_SEL_NM"]+'in relation to the debtor approved by factoring.'</expression>
                                <property name="dataType">string</property>
                            </structure>
                        </list-property>
                        <property name="resultSetColumn">Anexam totodata,</property>
                    </data>
                </cell>
            </row>
            <row id="249">
                <cell id="250">
                    <label id="253"/>
                </cell>
            </row>
