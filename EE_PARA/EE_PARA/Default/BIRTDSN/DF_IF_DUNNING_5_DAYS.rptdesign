                    <label id="625">
                        <property name="fontFamily">"Arial"</property>
                        <property name="fontWeight">bold</property>
                        <property name="textUnderline">underline</property>
                        <property name="textAlign">center</property>
                        <text-property name="text">pentru Banca Comerciala Romana SA:</text-property>
                    </label>
                </cell>
            </row>
            <row id="618">
                <cell id="619">
                    <label id="634"/>
                </cell>
            </row>
            <row id="632">
                <cell id="633">
                    <label id="635">
                        <property name="fontFamily">"Arial"</property>
                        <text-property name="text">Va rugam sa mentionati mai jos comentariile dumneavoastra cu privire la motivele intarzierii sau neplatii facturilor de mai sus si sa ne returnati prezenta scrisoare, pe cel mai scurt canal de comunicatie (fax, email, posta). </text-property>
                    </label>
                </cell>
            </row>
            <row id="630">
                <cell id="631">
                    <label id="667"/>
                </cell>
            </row>
            <row id="628">
                <cell id="629">
                    <text id="651">
                        <property name="fontFamily">"Arial"</property>
                        <property name="contentType">auto</property>
                        <text-property name="content"><![CDATA[	Motive de neefectuare a platii___________________________________________________
______________________________________________________________________________
______________________________________________________________________________

	Urmatoarele facturi nr. ________________________________________au fost/ vor fi platite de noi catre Banca Comerciala Romana SA, la data de____________, in suma de__________ ______________________________________________________________________________

	Alte mentiuni ________________________________________________________________
______________________________________________________________________________
______________________________________________________________________________

Data: 

Reprezentantul legal al societatii (numele, functia si semnatura) 
]]></text-property>
                    </text>
                    <label id="637"/>
                </cell>
            </row>
