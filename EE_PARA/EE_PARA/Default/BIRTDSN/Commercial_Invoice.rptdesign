 else if (row["TSU_PMT_CODE"]=="CASH")
 temp ="Payment On Delivery";
 else if (row["TSU_PMT_CODE"]=="EMTR")
 temp ="End Of Month Of Receipt";
 else if (row["TSU_PMT_CODE"]=="EPRD")
 temp ="End Of Period After Delivery";
 else if (row["TSU_PMT_CODE"]=="EPRR")
 temp ="End Of Period After Receipt";
 else if (row["TSU_PMT_CODE"]=="IREC")
 temp ="Payment On Receipt Of Invoice";
 else if (row["TSU_PMT_CODE"]=="PRMD")
 temp ="End Of Period After End Of Delivery Month";
 else if (row["TSU_PMT_CODE"]=="PRMR")
 temp ="End Of Period After End Of Receipt Month";
this.text = temp;]]></method>
