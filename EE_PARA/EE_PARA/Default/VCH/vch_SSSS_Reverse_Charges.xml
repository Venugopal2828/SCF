            <C_INTEREST_RATE2 FV_TYPE="" USED="N"/>
            <C_REF_NUMBER FV_TYPE="S">var type;
  var cash=DV.getFieldValue('CHG_CASH_IND');
   if (cash.equals('No')){
     type ='CUSTOMER';
   }else{
     type ='BANK';
   }
   DV.appendField(type);</C_REF_NUMBER>
