            <C_GL FV_TYPE="S">var cash=DV.getFieldValue('CHG_CASH_IND');
var currency = DV.getFieldValue('CHG_FLD_LOCAL_CUST_CCY');
if (cash.equals('Yes')){
   var country = DV.getCountryCode();
   var sql = "item_c='006" + "'" + " and cnty_code='" + country + "'" + " and item_name='" + currency + "'";
   DV.SYS_getTableData('FIELD_1_X','eximtrx.data_master',sql);
} else {
   var acc;
   acc = DV.getFieldValue('CHG_FLD_LOCAL_CUST_AC_NO');
   DV.appendField(acc);
}</C_GL>
            <C_SL FV_TYPE=""/>
            <C_CURRENCY FV_TYPE="F">CHG_FLD_LOCAL_CUST_CCY</C_CURRENCY>
            <N_AMT FV_TYPE="S">var dest=DV.getFieldValue('CHG_FLD_ALL_CHARGE_FOR');
  var amt=DV.getFieldValue('CHG_FLD_LOCAL_PAY_TOTALE_IN_PAYCCY');
  
  if(dest != null){
   if (dest.equals('F')){
     amt='0';
   }
   }
   DV.appendField(amt);</N_AMT>
