            <xml-property name="queryText"><![CDATA[SELECT T1.C_MAIN_REF, T1.FA_CUST_ID, T1.FA_CUST_NM, T1.FA_CNTR_DOC_NO, 
       T1.FA_LMT_CCY, T1.FA_LMT_AMT, T1.CHARGE_TP, 
       T2.REG_NO, T1.CHARGE_AMT, 
       T2.FA_LOAN_ID, T2.D_CREA_DATE    
       FROM EXIMTRX.ABLF_MASTER T1 LEFT JOIN EXIMTRX.ABLF_EM_LOAN T2 
       ON T1.C_MAIN_REF = T2.C_MAIN_REF WHERE 1=1]]></xml-property>
