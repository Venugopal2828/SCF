            <xml-property name="queryText"><![CDATA[SELECT 
DEAL_NO AS DealNo,
DEAL_TP AS DealType,
CNPT_ID AS CustName,
CNPT_FULL_NM AS CustFName,
NOSTRO_BK_SW_ADD AS SWADD,
TRX_CCY AS COMTCCY,
SEND_MT202_FLG AS SendMTFlag,
WHT_SEND_MT202_FLG AS WMTFlag,
SEND_MT202_VDT AS ValueDate,
CURRENT_STATUS,
DEAL_ACTION
FROM EXIMTRX.TRMM_MASTER
WHERE CURRENT_STATUS LIKE 'Back%' 
AND TRIM(DEAL_ACTION) NOT IN ('DeleteTicket','Cancel') 
AND TRIM(SEND_MT202_FLG) <> 'Yes'
AND TRIM(WHT_SEND_MT202_FLG) = 'Yes'
AND DEAL_TP IN ('IP','IT')]]></xml-property>
