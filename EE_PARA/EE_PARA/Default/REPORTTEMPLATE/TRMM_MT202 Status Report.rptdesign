            <method name="beforeOpen"><![CDATA[var sql = this.queryText;
if (params["InputValueDate"].value!= null &amp;&amp; params["InputValueDate"].value!= ""){
        sql=sql+" AND SEND_MT202_VDT >= TO_DATE('" + params["InputValueDate"] + "','YYYY-MM-DD') AND SEND_MT202_VDT < TO_DATE('" + params["InputValueDate"] + "','YYYY-MM-DD')+1";
}
this.queryText = sql;]]></method>
            <method name="afterOpen"><![CDATA[importPackage(Packages.com.cs.scf.util);
var slog = "-----TRMM MT202 Report-----\r\n" + this.queryText;
SCFBirtLog.getLogger().writeLog(slog);
]]></method>
