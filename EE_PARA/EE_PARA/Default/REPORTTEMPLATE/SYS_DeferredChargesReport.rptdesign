            <xml-property name="queryText"><![CDATA[SELECT  AA.PROD,AA.C_FUNCTION_ID,AA.C_TRX_REF,AA.CUSTID, AA.CUSTNM,AA.D_COMM_START_DATE, AA.C_CHARGE_COMMENT,AA.C_ORIG_CALC_CCY, AA.Y_ORIG_CALC_AMT, AA.C_CUSTOMER_AC  
FROM (
SELECT 'Export LC' AS PROD,T1.C_FUNCTION_ID,T1.C_TRX_REF,T4.BENE_ID AS CUSTID, T4.BENE_NM AS CUSTNM,T1.D_COMM_START_DATE, T1.C_CHARGE_COMMENT,T1.C_ORIG_CALC_CCY, T1.Y_ORIG_CALC_AMT, T1.C_CUSTOMER_AC  
FROM EXIMSYS.TRX_CHG_DEFERRED T1, EXIMTRX.EPLC_MASTER T4
WHERE T1.C_MAIN_REF = T4.C_MAIN_REF
UNION 
SELECT 'Export Collection' AS PROD,T1.C_FUNCTION_ID,T1.C_TRX_REF,T4.DRWR_ID AS CUSTID, T4.DRWR_NM AS CUSTNM,T1.D_COMM_START_DATE, T1.C_CHARGE_COMMENT,T1.C_ORIG_CALC_CCY, T1.Y_ORIG_CALC_AMT, T1.C_CUSTOMER_AC 
FROM EXIMSYS.TRX_CHG_DEFERRED T1, EXIMTRX.EXCO_MASTER T4
WHERE T1.C_MAIN_REF = T4.C_MAIN_REF 
UNION 
SELECT 'Bank Guarantee' AS PROD,T1.C_FUNCTION_ID,T1.C_TRX_REF,T4.APPL_ID AS CUSTID, T4.APPL_NM AS CUSTNM,T1.D_COMM_START_DATE, T1.C_CHARGE_COMMENT,T1.C_ORIG_CALC_CCY, T1.Y_ORIG_CALC_AMT, T1.C_CUSTOMER_AC    
FROM EXIMSYS.TRX_CHG_DEFERRED T1, EXIMTRX.GTEE_MASTER T4
WHERE T1.C_MAIN_REF = T4.C_MAIN_REF
UNION 
SELECT 'Import LC' AS PROD ,T1.C_FUNCTION_ID,T1.C_TRX_REF,T4.APPL_ID AS CUSTID, T4.APPL_NM AS CUSTNM,T1.D_COMM_START_DATE, T1.C_CHARGE_COMMENT,T1.C_ORIG_CALC_CCY, T1.Y_ORIG_CALC_AMT, T1.C_CUSTOMER_AC 
FROM EXIMSYS.TRX_CHG_DEFERRED T1, EXIMTRX.IPLC_MASTER T4
WHERE T1.C_MAIN_REF = T4.C_MAIN_REF
UNION 
SELECT 'Import Collection' AS PROD ,T1.C_FUNCTION_ID,T1.C_TRX_REF,T4.DRWE_ID AS CUSTID, T4.DRWE_NM AS CUSTNM,T1.D_COMM_START_DATE, T1.C_CHARGE_COMMENT,T1.C_ORIG_CALC_CCY, T1.Y_ORIG_CALC_AMT, T1.C_CUSTOMER_AC  
FROM EXIMSYS.TRX_CHG_DEFERRED T1, EXIMTRX.IMCO_MASTER T4
WHERE T1.C_MAIN_REF = T4.C_MAIN_REF 
UNION 
SELECT 'Shipping Guarantee' AS PROD ,T1.C_FUNCTION_ID,T1.C_TRX_REF,T4.APPL_ID AS CUSTID, T4.APPL_NM AS CUSTNM,T1.D_COMM_START_DATE, T1.C_CHARGE_COMMENT,T1.C_ORIG_CALC_CCY, T1.Y_ORIG_CALC_AMT, T1.C_CUSTOMER_AC 
FROM EXIMSYS.TRX_CHG_DEFERRED T1, EXIMTRX.SHGT_MASTER T4
WHERE T1.C_MAIN_REF = T4.C_MAIN_REF 
) AA 
WHERE 1=1
]]></xml-property>
