            <method name="beforeOpen"><![CDATA[var sql = this.queryText;

if (params["rptpara_CIF"].value!= null &amp;&amp; params["rptpara_CIF"].value!= ""){

        sql=sql+" AND CUSTID = '"+params["rptpara_CIF"]+"'";
}
if (params["rptpara_StartDT"].value!= null &amp;&amp; params["rptpara_StartDT"].value!= ""){

        sql=sql+" AND AA.D_COMM_START_DATE >= TO_DATE('" + params["rptpara_StartDT"] + "','YYYY-MM-DD')";
}
if (params["rptpara_EndDT"].value!= null &amp;&amp; params["rptpara_EndDT"].value!= ""){

        sql=sql+" AND AA.D_COMM_START_DATE <= TO_DATE('" + params["rptpara_EndDT"] + "','YYYY-MM-DD')";
}
this.queryText = sql;
