            <xml-property name="queryText"><![CDATA[SELECT T1.FA_ANCHOR_NM,
       T1.FA_CNTR_DOC_NO,
       T1.FA_ANCHOR_CCY,
       T1.FA_ANCHOR_AMT,
       T1.FA_COUNTER_NM,
       T1.C_MAIN_REF,
       T1.FA_BUSI_TYPE,
       T2.FA_DOC_NO,
       T2.FA_DOC_REF,
       T2.FA_DOC_AMT,
       T2.FA_CRN_INV_LINK_NO,
       T2.FA_ADJ_DT
  FROM EXIMTRX.FADA_MASTER T1 LEFT JOIN EXIMTRX.INVC_MASTER T2 ON T1.C_MAIN_REF=T2.FSBC_REF
  WHERE T1.FA_BUSI_STATUS = 'SBR' 
        AND (T2.FA_DOC_STATUS = 'Applied')
        AND T2.FA_DOC_TYPE = '2']]></xml-property>
