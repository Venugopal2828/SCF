            <xml-property name="queryText"><![CDATA[select T1.C_MAIN_REF,
	   T1.FA_ANCHOR_NM,
       T1.FA_CNTR_DOC_NO,
       T1.FA_ANCHOR_CCY,
       T1.FA_ANCHOR_AMT,
       T1.FA_COUNTER_NM,
       T1.FA_TTL_INV_NO,
       T1.FA_TTL_ADJ_AMT,
       T1.FA_TTL_ADJ_BAL,
       T1.AMT_AVAL_FOR_FUNDING,
       T1.FA_TTL_INV_LOAN_AMT,
       T1.FA_TTL_LOAN_BAL,
       T1.FA_BUSI_TYPE,
       T1.FA_BUSI_FUNC,
       T1.FA_BUSI_STATUS,
       T1.FA_CNTR_REF,
       T1.FA_RELATION_STATUS,
       T1.INV_FIN_MODE,(CASE WHEN T1.INV_FIN_MODE = 'POOL' THEN 'POOL' END) AS FIN_MODE
  FROM EXIMTRX.FADA_MASTER T1
  WHERE T1.FA_BUSI_STATUS = 'SBR' AND C_TRX_STATUS = 'M'
]]></xml-property>
