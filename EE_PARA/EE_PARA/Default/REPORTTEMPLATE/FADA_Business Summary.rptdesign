            <method name="beforeOpen"><![CDATA[var sql = this.queryText;
if(params["Anchor Customer Name"].value != ""&amp;&amp;params["Anchor Customer Name"].value != null){
        sql=sql+ " AND LOWER(FA_ANCHOR_NM) LIKE LOWER('%"+ params["Anchor Customer Name"]+"%')";   
}
if(params["Agreement Document No"].value != ""&amp;&amp;params["Agreement Document No"].value != null){
        sql=sql+ " AND FA_CNTR_DOC_NO = '"+ params["Agreement Document No"]+"'";  
} 
if(params["Business Type"].value != ""&amp;&amp;params["Business Type"].value != null){
        sql=sql+ " AND FA_BUSI_TYPE = '"+ params["Business Type"]+"'";  
} 
sql=sql+" ORDER BY FA_ANCHOR_NM,FA_ANCHOR_CCY,C_MAIN_REF";
this.queryText = sql;
]]></method>
            <method name="afterOpen"><![CDATA[importPackage(Packages.com.cs.scf.util);
var slog = "-----FADA_Business Summary Report-----\r\n" + this.queryText;
SCFBirtLog.getLogger().writeLog(slog);
]]></method>
