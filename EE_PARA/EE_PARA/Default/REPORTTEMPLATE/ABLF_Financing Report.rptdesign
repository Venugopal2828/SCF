            <xml-property name="queryText"><![CDATA[SELECT T1.C_MAIN_REF, T1.FA_CUST_ID, T1.FA_CUST_NM, T1.FA_CNTR_DOC_NO, 
       T1.FA_LMT_CCY, T1.FA_LMT_AMT, T1.FA_MAX_LOAN_PERC, 
       T2.REG_NO, T2.FA_LOAN_ID, T2.FA_LOAN_VAL_DT, T2.FA_LOAN_DUE_DT, T2.FA_TTL_LOAN_AMT, T2.LOAN_BAL
       FROM EXIMTRX.ABLF_EM_LOAN T2 LEFT JOIN EXIMTRX.ABLF_MASTER T1 ON T2.C_MAIN_REF = T1.C_MAIN_REF
       WHERE 1=1]]></xml-property>
