            <method name="beforeOpen"><![CDATA[var sql = this.queryText;
if(params["Applicant Name"].value != ""&amp;&amp;params["Applicant Name"].value != null){
        sql=sql+ " AND LOWER(T1.FA_CUST_NM) LIKE LOWER('%"+ params["Applicant Name"]+"%')";   
}
if(params["Contract No"].value != ""&amp;&amp;params["Contract No"].value != null){
        sql=sql+ " AND T1.FA_CNTR_DOC_NO = '"+ params["Contract No"]+"'";  
} 
if (params["From Date"].value!= null &amp;&amp; params["From Date"].value!= ""){
        sql=sql+" AND T2.FA_LOAN_DUE_DT >= TO_DATE('" + params["From Date"] + "','YYYY-MM-DD')";
}

if (params["End Date"].value!= null &amp;&amp; params["End Date"].value!= ""){
        sql=sql+" AND T2.FA_LOAN_DUE_DT <= TO_DATE('" + params["End Date"] + "','YYYY-MM-DD')";
}
sql=sql+" ORDER BY T1.FA_CUST_NM, T1.FA_CNTR_DOC_NO";
this.queryText = sql;
]]></method>
            <method name="afterOpen"><![CDATA[importPackage(Packages.com.cs.scf.util);
var slog = "-----ABLF_Financing Report-----\r\n" + this.queryText;
SCFBirtLog.getLogger().writeLog(slog);
]]></method>
