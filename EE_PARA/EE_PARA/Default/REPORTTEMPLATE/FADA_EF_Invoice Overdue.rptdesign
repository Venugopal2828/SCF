            <method name="beforeOpen"><![CDATA[var sql = this.queryText;
if(params["Seller Name"].value != ""&amp;&amp;params["Seller Name"].value != null){
        sql=sql+ " AND LOWER(T3.FA_SEL_NM) LIKE LOWER('%"+ params["Seller Name"]+"%')";   
}
if(params["Agreement Document No"].value != ""&amp;&amp;params["Agreement Document No"].value != null){
        sql=sql+ " AND T3.FA_CNTR_DOC_NO = '"+ params["Agreement Document No"]+"'";  
} 
sql=sql+" ORDER BY T3.FA_SEL_NM,T3.FA_LMT_CCY,T3.FA_DOC_REF";
this.queryText = sql;
]]></method>
            <method name="afterOpen"><![CDATA[importPackage(Packages.com.cs.scf.util);
var slog = "-----FADA_EF_Invoice Overdue Report-----\r\n" + this.queryText;
SCFBirtLog.getLogger().writeLog(slog);
]]></method>
