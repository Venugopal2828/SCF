            <xml-property name="queryText"><![CDATA[SELECT T3.*, T4.D_BU_SOD_DATE - T3.FA_DOC_DUE_DT AS OVERDUE_DS FROM 
(SELECT T1.C_BK_GROUP_ID,
       T1.C_UNIT_CODE,
       T1.FA_SEL_NM,
       T1.FA_CNTR_DOC_NO,
       T1.FA_LMT_CCY,
       T1.FA_LMT_AMT,
       T1.FA_BUYER_NM,
       T1.C_MAIN_REF,
       T1.FA_BUSI_TYPE,
       T2.FA_DOC_REF,
       T2.FA_DOC_NO,
       T2.FA_ADJ_BAL,T2.FA_ADJ_AMT,
       T2.FA_INV_LOAN_BAL,
       T2.FA_DOC_DUE_DT,
       T2.FA_DOC_STATUS
  FROM EXIMTRX.FADA_MASTER T1 LEFT JOIN EXIMTRX.INVC_MASTER T2
  ON T1.C_MAIN_REF=T2.FSBC_REF
  WHERE T1.FA_BUSI_TYPE ='EF'
        AND T2.FA_ADJ_BAL > 0
        AND (T2.FA_DOC_STATUS = 'Active' OR T2.FA_DOC_STATUS = 'Financed')
        AND T2.FA_DOC_TYPE = '1' 
        AND T1.C_TRX_STATUS = 'M') T3, EXIMSYS.TRX_SOD_EOD T4
WHERE T3.C_UNIT_CODE = T4.C_UNIT_CODE AND T3.C_BK_GROUP_ID = T4.C_BK_GROUP_ID 
		AND T3.FA_DOC_DUE_DT - T4.D_BU_SOD_DATE <0]]></xml-property>
