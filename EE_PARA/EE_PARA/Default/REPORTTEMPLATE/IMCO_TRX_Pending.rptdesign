            <xml-property name="queryText"><![CDATA[SELECT DRWE_ID ,DRWE_NM,C_MAIN_REF ,
COLL_CCY ,COLL_TRX_CCY_AMT ,
C_FUNC_SHORT_NAME ,C_UNIT_CODE ,
C_CP_UNIT_CODE ,D_CREA_DATE 
FROM IMCO_MASTER  WHERE
( C_TRX_STATUS ='P' OR C_TRX_STATUS ='S')  ]]></xml-property>
