            <xml-property name="queryText"><![CDATA[SELECT T1.FA_ANCHOR_NM,
       T1.FA_ANCHOR_ID,
       T1.FA_CNTR_DOC_NO,
       T1.FA_ANCHOR_CCY,
       T1.FA_CNTR_REF,
       T1.FA_BUSI_TYPE,
       T1.FA_COUNTER_NM,
       T1.FA_COUNTER_ID,
       T2.LM_CRED_LMT AS CCL_CRED_LMT,
       T2.LM_CRED_LMT-T2.LM_OVER_OUT-T2.LM_OUTD_APV-T2.LM_OUTD_APL+T2.LM_OUTC_APV AS CCL_AVAI_AMT,
       T2.LM_DUE_DAY,
       T3.LM_CRED_LMT AS CSL_CRED_LMT,
       T3.LM_CRED_LMT-T3.LM_OVER_OUT-T3.LM_OUTD_APV-T3.LM_OUTD_APL+T3.LM_OUTC_APV AS CSL_AVAI_AMT
  FROM EXIMTRX.FADA_MASTER T1 LEFT JOIN EXIMSYS.STDS_CCL T2 ON T1.FA_ANCHOR_ID=T2.LM_CUST_ID
      AND T1.FA_CNTR_REF=T2.LM_RCUST_ID AND T1.FA_ANCHOR_CCY=T2.LM_BASE_CCY
  LEFT JOIN EXIMSYS.STDS_CSL T3 ON T1.FA_ANCHOR_ID=T3.LM_CUST_ID
      AND T1.FA_CNTR_REF=T3.LM_RCUST_ID AND T1.FA_ANCHOR_CCY=T3.LM_SUB_CCY AND T1.FA_COUNTER_ID=T3.LM_CSL_DESC
  WHERE T1.FA_BUSI_STATUS = 'SBR' AND C_TRX_STATUS = 'M']]></xml-property>
