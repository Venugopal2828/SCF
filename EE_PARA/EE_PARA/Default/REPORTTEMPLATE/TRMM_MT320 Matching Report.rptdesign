            <xml-property name="queryText"><![CDATA[SELECT 
DEAL_NO AS DealNo,
CNPT_FULL_NM AS CustFName,
DEAL_TP,
CASE
	WHEN (DEAL_TP = 'IT') THEN 'Borrow In' 
	WHEN (DEAL_TP = 'IP') THEN 'Lend Out'
	ELSE '' END AS DealType,
TRX_CCY AS COMTCCY,
CNPT_SWADD AS SWADD,
C_TRX_STATUS,
CLS_FLG,
SEND_MT320_FLG,
SEND_MT320_VDT,
MT320_MATCH_STATUS,
CASE
	WHEN (MT320_MATCH_STATUS = 0) THEN 'Send Out'
	WHEN (MT320_MATCH_STATUS = 1) THEN 'Receive ACK'
	WHEN (MT320_MATCH_STATUS = 20) THEN 'Match'
	WHEN (MT320_MATCH_STATUS = -4) THEN 'Receive MT320'
	ELSE '' END AS MT320_MAT_STA
FROM EXIMTRX.TRMM_MASTER
WHERE C_TRX_STATUS = 'M' 
AND CLS_FLG = 'No' 
AND SEND_MT320_FLG = 'Yes' 
AND SEND_MT320_VDT <= SYSDATE]]></xml-property>
