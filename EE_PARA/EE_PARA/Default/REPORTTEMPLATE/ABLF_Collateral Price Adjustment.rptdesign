            <xml-property name="queryText"><![CDATA[SELECT T1.C_MAIN_REF, T1.REG_NO, T1.COLLAT_ID, T1.ADJ_DATE, T1.PRICE,
       T2.FA_CUST_ID, T2.FA_CUST_NM, T2.FA_CNTR_DOC_NO,T2.FA_LMT_CCY,
       T3.REG_INSPEC_NM ,T4.COLLAT_NM
       FROM EXIMTRX.ABLF_COLL_ADJ T1 LEFT JOIN EXIMTRX.ABLF_MASTER T2 ON T1.C_MAIN_REF = T2.C_MAIN_REF
       LEFT JOIN EXIMTRX.ABLF_EM_REG T3 ON T1.REG_NO = T3.REG_NO 
       LEFT JOIN (SELECT DISTINCT COLLAT_ID,COLLAT_NM FROM EXIMTRX.ABLF_COLL) T4 ON T1.COLLAT_ID = T4.COLLAT_ID
       WHERE 1=1 AND T1.PRICE>0 AND T1.C_TRX_STATUS='M']]></xml-property>
