            <xml-property name="queryText"><![CDATA[         
        select T1.C_MAIN_REF,
	     T1.FA_ANCHOR_NM,
       T1.FA_CNTR_DOC_NO,
       T1.FA_ANCHOR_CCY,
       T1.FA_ANCHOR_AMT,
       T1.FA_COUNTER_NM,
       T1.FA_TTL_PO_AMT,
       T1.FA_TTL_PO_NO,
       T1.PO_AVAL_FOR_FUNDING,
       T2.PO_LOAN_AMT,
       T1.FA_RELATION_STATUS,
       T1.FA_MAX_LOAN_PERC,
       T2.PO_LOAN_BAL,
       T2.PO_NO,
       T2.PO_AMT
  FROM EXIMTRX.FADA_MASTER T1 LEFT JOIN (
        SELECT FA_SBR_REF,PO_NO,PO_LOAN_BAL,PO_AMT,PO_LOAN_AMT
        FROM EXIMTRX.POMM_MASTER WHERE PO_STATUS IN ('Active', 'Loan', 'Closed') 
  ) T2 ON T1.C_MAIN_REF  = T2.FA_SBR_REF
  WHERE T1.FA_BUSI_STATUS = 'SBR'
        AND T1.FA_BUSI_TYPE = 'POF' AND T1.C_TRX_STATUS = 'M']]></xml-property>
