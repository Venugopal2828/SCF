            <xml-property name="queryText"><![CDATA[SELECT T1.LC_NO,
       T1.C_MAIN_REF,
       T3.DRAWING_REF,
       T1.APPL_ID,
       T1.APPL_NM,
       T2.BENE_NM,
       T2.CNTY_CODE,
       T2.LC_CCY,
       T3.PRES_AMT,
       T3.PRES_BK_NM,
       T2.AVAL_BY,
       T3.PRES_DT,
       T2.EXPIRY_DT, 
       T1.C_UNIT_CODE, 
       T1.C_CP_UNIT_CODE,
       T1.LOCAL_CCY,
       T1.SG_BAL,
       (CASE WHEN T1.SG_CCY='USD' THEN 1
             WHEN T1.SG_CCY<>'USD' THEN (SELECT F_VALUE FROM EXIMSYS.STD_EXCHAN_RATE WHERE C_FROM_CCY = T1.SG_CCY AND C_TO_CCY = 'USD' AND C_BK_GROUP_ID = 'CSBANK' AND C_CNTY_CODE = 'US' AND C_DESC_ID = 'Booking Rate') 
             END) AS EXCH_RATE 
  FROM EXIMTRX.IPLC_MASTER T2  
  RIGHT JOIN EXIMTRX.IPLC_EM_NEGO T3 ON T2.C_MAIN_REF=T3.C_MAIN_REF 
  LEFT JOIN EXIMTRX.SHGT_MASTER T1 ON T1.LC_NO=T2.C_MAIN_REF
  WHERE T1.C_TRX_STATUS = 'M'  ]]></xml-property>
