            <method name="beforeOpen"><![CDATA[var sql = this.queryText;
if(params["Buyer Name"].value != ""&amp;&amp;params["Buyer Name"].value != null){
       sql=sql+ " AND LOWER(T1.FA_BUYER_NM) LIKE LOWER('%"+ params["Buyer Name"]+"%')";   
}
if(params["Main Ref Number"].value != ""&amp;&amp;params["Main Ref Number"].value != null){
        sql=sql+ " AND T1.C_MAIN_REF = '"+ params["Main Ref Number"]+"'";  
}
sql=sql+" ORDER BY T1.FA_BUYER_NM,T1.FA_LMT_CCY,T1.C_MAIN_REF";
this.queryText = sql;
]]></method>
            <method name="afterOpen"><![CDATA[importPackage(Packages.com.cs.scf.util);
var slog = "-----FADA_IF_Business Summary Report-----\r\n" + this.queryText;
SCFBirtLog.getLogger().writeLog(slog);
]]></method>
