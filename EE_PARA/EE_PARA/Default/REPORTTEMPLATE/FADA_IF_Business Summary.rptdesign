            <xml-property name="queryText"><![CDATA[select T1.C_MAIN_REF,
	   T1.FA_SEL_NM,
       T1.FA_CNTR_DOC_NO,
       T1.FA_LMT_CCY,
       T1.FA_LMT_AMT,
       T1.FA_BUYER_NM,
       T2.FA_TTL_INV_NO,
       T2.FA_TTL_INV_AMT-T2.FA_TTL_CRN_AMT AS ADJ_AMT, 
       T1.FA_TTL_INV_LOAN_AMT,
       T1.FA_BUSI_TYPE,
       T1.FA_BUSI_FUNC,
       T1.FA_BUSI_STATUS,
       T1.FA_CNTR_REF,
       T1.FA_RELATION_STATUS, 
       T3.FA_PMT_AMT_SUM 
  FROM EXIMTRX.FADA_MASTER T1 
  LEFT JOIN EXIMTRX.FAEF_MASTER T2 
  ON T1.C_MAIN_REF= T2.FA_SBR_REF 
  LEFT JOIN EXIMTRX.FAEF_PMT T3  
  ON  T2.C_MAIN_REF=T3.C_MAIN_REF 
  WHERE T1.C_TRX_STATUS = 'M' AND T1.FA_BUSI_TYPE='IF'
]]></xml-property>
