            <xml-property name="queryText"><![CDATA[SELECT T1.FA_ANCHOR_NM,
       T1.FA_CNTR_DOC_NO,
       T1.FA_LMT_CCY,
       T1.FA_LMT_AMT,
       T1.FA_COUNTER_NM,
       T1.FA_AUTO_FIN,
       T1.C_MAIN_REF,
       T1.FA_BUSI_TYPE,
       T2.FA_DOC_NO,
       T2.FA_DOC_REF,
       T2.FA_ADJ_AMT,
       T3.FA_DSP_DT,
       T2.FA_DOC_DUE_DT,
       T3.FA_DSP_AMT,
       T3.FA_NOTIFY_BY_NM,
       T3.FA_DSP_RSN_CODE,
       T3.FA_DSP_STATUS,
       T3.FA_ACTION_CODE 

  FROM EXIMTRX.FADA_MASTER T1 LEFT JOIN EXIMTRX.INVC_MASTER T2 ON T1.C_MAIN_REF=T2.FSBC_REF
  LEFT JOIN EXIMTRX.INVC_DSP T3 ON T2.FA_DOC_REF=T3.FA_DOC_REF 
  WHERE T1.FA_BUSI_TYPE= 'IF' 
        AND T2.FA_DSP_AMT > 0 
        AND T2.FA_DOC_TYPE = '1' AND T1.C_TRX_STATUS = 'M']]></xml-property>
