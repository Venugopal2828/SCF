                    <property name="dataType">date-time</property>
                    <property name="nativeDataType">93</property>
                </structure>
                <structure>
                    <property name="position">21</property>
                    <property name="name">FA_AUTO_FINANCING</property>
                    <property name="nativeName">FA_AUTO_FINANCING</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT T1.FA_ANCHOR_NM,
       T1.FA_CNTR_DOC_NO,
       T1.FA_ANCHOR_CCY,
       T1.FA_ANCHOR_AMT,
       T1.FA_COUNTER_NM,
       T1.XBOR_RT + T1.FA_IRT_SPREAD AS FA_LOAN_INT_RT,
       T1.FA_REBATE_RATE,
       T1.C_MAIN_REF,
       T1.FA_BUSI_TYPE,
       T2.FA_DOC_NO,
       T2.FA_DOC_REF,
       T2.FA_ADJ_AMT,
       T3.FA_INV_LOAN_AMT,
       T2.FA_DOC_DUE_DT,
       T3.FA_REBATE_AMT,
       T3.FA_LOAN_INT_SM_AMT,
       T3.FA_INT_CHG_TYPE,
       T4.C_FUNC_SHORT_NAME,
       (CASE WHEN T3.FA_INT_CHG_TYPE='1' THEN 'Upfront'
       WHEN T3.FA_INT_CHG_TYPE='2' THEN 'Settlement'
       ELSE '' END) AS CHG_TYPE,
       T3.FA_LOAN_VAL_DT,
       (CASE WHEN T4.C_FUNC_SHORT_NAME='AutoFinancing' THEN 'Yes' ELSE 'No' END) AS FA_AUTO_FINANCING
  FROM EXIMTRX.FADA_MASTER T1 LEFT JOIN EXIMTRX.INVC_MASTER T2 ON T1.C_MAIN_REF=T2.FSBC_REF
  LEFT JOIN EXIMTRX.INVC_LOAN T3 ON T2.FA_DOC_REF=T3.FA_DOC_REF
  LEFT JOIN EXIMTRX.FAEF_LOAN T4 ON T3.FA_LOAN_ID=T4.C_MAIN_REF
  WHERE T1.FA_BUSI_STATUS = 'SBR' 
        AND (T2.FA_DOC_STATUS = 'Settled' OR T2.FA_DOC_STATUS = 'Refunded' 
        OR T2.FA_DOC_STATUS = 'Financed')
        AND T2.FA_DOC_TYPE = '1' AND T1.C_TRX_STATUS = 'M']]></xml-property>
