            <method name="beforeOpen"><![CDATA[var sql = this.queryText;
if(params["Anchor Customer Name"].value != ""&amp;&amp;params["Anchor Customer Name"].value != null){
        sql=sql+ " AND LOWER(T1.FA_ANCHOR_NM) LIKE LOWER('%"+ params["Anchor Customer Name"]+"%')";   
}
if(params["Agreement Document No"].value != ""&amp;&amp;params["Agreement Document No"].value != null){
        sql=sql+ " AND T1.FA_CNTR_DOC_NO = '"+ params["Agreement Document No"]+"'";  
} 
if (params["From Date"].value!= null &amp;&amp; params["From Date"].value!= ""){
        sql=sql+" AND T3.FA_LOAN_VAL_DT >= TO_DATE('" + params["From Date"] + "','YYYY-MM-DD')";
}    
if (params["End Date"].value!= null &amp;&amp; params["End Date"].value!= ""){
        sql=sql+" AND T3.FA_LOAN_VAL_DT <= TO_DATE('" + params["End Date"] + "','YYYY-MM-DD')";
}
if (params["Business Type"].value!= null &amp;&amp; params["Business Type"].value!= ""){
        sql=sql+" AND T1.FA_BUSI_TYPE = '"+ params["Business Type"]+"'"; 
}
if (params["Auto Financing?"].value == 'Yes'){
        sql=sql+" AND T4.C_FUNC_SHORT_NAME = 'AutoFinancing'"; 
}
if (params["Auto Financing?"].value == 'No'){
      sql=sql+" AND T4.C_FUNC_SHORT_NAME != 'AutoFinancing'"; 
}
sql=sql+" ORDER BY T1.FA_ANCHOR_NM,T1.FA_ANCHOR_CCY,T2.FA_DOC_REF";
this.queryText = sql;]]></method>
            <method name="afterOpen"><![CDATA[importPackage(Packages.com.cs.scf.util);
var slog = "-----FADA_Invoice Financing Report-----\r\n" + this.queryText;
SCFBirtLog.getLogger().writeLog(slog);
]]></method>
