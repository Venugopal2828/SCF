            <method name="beforeOpen"><![CDATA[var sql = this.queryText;
if(params["Customer Name"].value != ""&amp;&amp;params["Customer Name"].value != null){
        sql=sql+ " AND LOWER(FA_CUST_NM) LIKE LOWER('%"+ params["Customer Name"]+"%')";   
}
if(params["Contract Document No"].value != ""&amp;&amp;params["Contract Document No"].value != null){
        sql=sql+ " AND FA_CNTR_DOC_NO = '"+ params["Contract Document No"]+"'";  
} 
if(params["Main Reference No"].value != ""&amp;&amp;params["Main Reference No"].value != null){
        sql=sql+ " AND C_MAIN_REF = '"+ params["Main Reference No"]+"'";  
} 
sql=sql+" ORDER BY C_MAIN_REF,FA_CNTR_DOC_NO";
this.queryText = sql;]]></method>
            <method name="afterOpen"><![CDATA[importPackage(Packages.com.cs.scf.util);
var slog = "-----ABLF_TRX_Pending Report-----\r\n" + this.queryText;
SCFBirtLog.getLogger().writeLog(slog);
]]></method>
