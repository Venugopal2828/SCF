            <xml-property name="queryText"><![CDATA[SELECT C_MAIN_REF,
					   FA_CNTR_REF,
					   FA_CNTR_DOC_NO,
					   FA_CUST_NM,
					   TRX_DT,
					   C_USER_ID,
					   C_FUNC_SHORT_NAME 
					FROM EXIMTRX.ABLF_MASTER 
					WHERE (C_TRX_STATUS = 'P' OR C_TRX_STATUS = 'S') ]]></xml-property>
