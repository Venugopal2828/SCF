            <method name="beforeOpen"><![CDATA[var sql = this.queryText;
if (params["Start Date"].value!= null &amp;&amp; params["Start Date"].value!= ""){
        sql=sql+" AND DUE_DT >= TO_DATE('" + params["Start Date"] + "','YYYY-MM-DD')";
}
if (params["End Date"].value!= null &amp;&amp; params["End Date"].value!= ""){
        sql=sql+" AND DUE_DT <= TO_DATE('" + params["End Date"] + "','YYYY-MM-DD')";
}
sql=sql+" ORDER BY C_MAIN_REF";
this.queryText = sql;
]]></method>
            <method name="afterOpen"><![CDATA[importPackage(Packages.com.cs.scf.util);
var slog = "-----EXCO_Estimate Settlement Report-----\r\n" + this.queryText;
SCFBirtLog.getLogger().writeLog(slog);
]]></method>
