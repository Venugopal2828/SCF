            <xml-property name="queryText"><![CDATA[         
       SELECT 
    C_MAIN_REF,
    DRWR_ID,
    DRWR_NM,
    DRWE_NM,
    COLL_BK_NM,
    DELVR_DOC_AGST,
    COLL_CCY,
    COLL_TRX_CCY_AMT,
    COLL_TRX_CCY_BAL,
    COLL_DT,
    DUE_DT,
    C_UNIT_CODE,
    C_CP_UNIT_CODE,
    LOCAL_AMT,
    PMT_DT,
    LOCAL_RATE,
    C_TRX_STATUS,
    FLOOR(SYSDATE - TO_DATE(COLL_DT)) AS Aging,
    FLOOR(TO_DATE(DUE_DT) - SYSDATE) AS Estimated
FROM 
    EXIMTRX.EXCO_MASTER
WHERE DUE_DT IS NOT NULL  AND C_TRX_STATUS = 'M' 
      
       
	
	]]></xml-property>
