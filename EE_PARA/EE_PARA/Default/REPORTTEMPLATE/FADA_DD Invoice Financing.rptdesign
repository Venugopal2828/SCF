            <xml-property name="queryText"><![CDATA[SELECT T1.FA_ANCHOR_NM,
       T1.FA_CNTR_DOC_NO,
       T1.FA_ANCHOR_CCY,
       T1.FA_ANCHOR_AMT,
       T1.FA_COUNTER_NM,
       T1.C_MAIN_REF,
       T1.FA_BUSI_TYPE,
       T2.FA_DOC_NO,
       T2.FA_DOC_REF,
       T2.FA_ADJ_AMT,
       T2.FA_DOC_DUE_DT,
       T3.FA_LOAN_VAL_DT,
       T3.FA_INV_LOAN_AMT,
       T3.FA_LOAN_DAYS,
       T3.FA_LOAN_INT_RT,
       T3.FA_LOAN_INT_AMT,
       T3.FA_INV_LOAN_AMT - T3.FA_LOAN_INT_AMT AS FA_RECV_AMT
  FROM EXIMTRX.FADA_MASTER T1 LEFT JOIN EXIMTRX.INVC_MASTER T2 ON T1.C_MAIN_REF=T2.FSBC_REF
  LEFT JOIN EXIMTRX.INVC_LOAN T3 ON T2.FA_DOC_REF=T3.FA_DOC_REF
  WHERE T1.FA_BUSI_STATUS = 'SBR' AND T1.FA_BUSI_TYPE = 'DD'
        AND T2.FA_DOC_STATUS = 'Settled'
        AND T2.FA_DOC_TYPE = '1'
        AND T1.C_TRX_STATUS = 'M']]></xml-property>
