            <xml-property name="queryText"><![CDATA[SELECT T1.LC_NO,
       T2.DRAWING_REF,
       T1.APPL_ID,
       T1.APPL_NM,
       T1.BENE_NM,
       T2.PRES_BK_NM,
       T1.AVAL_BY,
       T1.LC_CCY,
       T2.STL_AMT,
       T2.LOCAL_RATE,
       T1.LOCAL_CCY,
       T2.PRES_DT,
       T2.MATURITY_DT, 
       T1.C_UNIT_CODE, 
       T1.C_CP_UNIT_CODE,
       T3.CPYT_DR_VAL_DATE,
       T2.STL_AMT, 
       T1.LC_BAL    
  FROM EXIMTRX.IPLC_EM_NEGO T2 
  JOIN EXIMTRX.IPLC_MASTER T1 
  ON T1.C_MAIN_REF=T2.C_MAIN_REF  
  LEFT JOIN EXIMSYS.CPYT_DEBIT T3 
  ON T1.C_MAIN_REF=T3.C_MAIN_REF 
  AND T2.TTL_DR_AMT = T3.CPYT_DR_AMT_TXCCY
  WHERE T3.CPYT_DR_VAL_DATE IS NOT NULL 
    AND T1.C_TRX_STATUS = 'M' ]]></xml-property>
