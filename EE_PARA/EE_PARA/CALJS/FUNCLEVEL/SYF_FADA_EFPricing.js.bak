csFuncLevelProto.SYF_FADA_Cal_FA_TTL_OTH_CHG = function() {
    try {

        document.MAINFORM.FA_TTL_OTH_CHG.value = SYS_BeFloat(document.MAINFORM.FA_EF_OTH_CHG_AMT.value) + SYS_BeFloat(document.MAINFORM.FA_IF_OTH_CHG_AMT.value);
        document.MAINFORM.FA_TTL_OTH_CHG.value = SYT_CCY_AMT(document.MAINFORM.FA_EF_OTH_CHG_CCY.value, document.MAINFORM.FA_TTL_OTH_CHG.value);
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

csFuncLevelProto.SYF_FADA_Cal_FA_TTL_COMM_RT = function() {
    try {

        document.MAINFORM.FA_TTL_COMM_RT.value = (SYS_BeFloat(document.MAINFORM.FA_IF_COMM_RT.value) * 1000 + SYS_BeFloat(document.MAINFORM.FA_EF_COMM_RT.value) * 1000) / 1000;
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

