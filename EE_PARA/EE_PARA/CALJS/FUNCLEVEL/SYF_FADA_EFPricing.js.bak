csFuncLevelProto.SYF_FADA_Chk_isFixRateOrNull = function(value) {
    try {

        if ("1" == value) {
            return true;
        }
        return SYF_FADA_Chk_isEmpty(value);
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

