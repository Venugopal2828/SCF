csFuncLevelProto.SYF_FADA_MPO_LOAN_RT = function() {
    try {

        if (document.MAINFORM.FA_INV_CCY1.value != null && document.MAINFORM.FA_INV_CCY1.value != '') {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE1, 'M');
        } else {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE1, 'P');
            document.MAINFORM.FA_LOAN_RT_TYPE1.value = 0;
        }
        if (document.MAINFORM.FA_INV_CCY2.value != null && document.MAINFORM.FA_INV_CCY2.value != '') {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE2, 'M');
        } else {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE2, 'P');
            document.MAINFORM.FA_LOAN_RT_TYPE2.value = 0;
        }
        if (document.MAINFORM.FA_INV_CCY3.value != null && document.MAINFORM.FA_INV_CCY3.value != '') {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE3, 'M');
        } else {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE3, 'P');
            document.MAINFORM.FA_LOAN_RT_TYPE3.value = 0;
        }
        if (document.MAINFORM.FA_INV_CCY4.value != null && document.MAINFORM.FA_INV_CCY4.value != '') {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE4, 'M');
        } else {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE4, 'P');
            document.MAINFORM.FA_LOAN_RT_TYPE4.value = 0;
        }
        if (document.MAINFORM.FA_INV_CCY5.value != null && document.MAINFORM.FA_INV_CCY5.value != '') {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE5, 'M');
        } else {
            SYT_ChangeFldClass(document.MAINFORM.FA_LOAN_RT_TYPE5, 'P');
            document.MAINFORM.FA_LOAN_RT_TYPE5.value = 0;
        }
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

