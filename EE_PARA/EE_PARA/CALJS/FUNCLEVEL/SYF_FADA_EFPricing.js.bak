var csFuncLevelProto = Object.create(csFuncLevelBaseProto || {});
csFuncLevelProto.SYF_FADA_Chk_confirm = function() {
    try {

        if (document.MAINFORM.FA_APPL_LMT_CCY.value == '') {
            if (!confirm('The Credit Currency is null, the Buyer ID is invalid!')) {

                return false;
            }
        }
        if (document.MAINFORM.FA_BUYER_ID.value == '') {
            alert('Please select buyer!');
            return false;
        }
        if (document.MAINFORM.FA_EF_COMM_RT.value == 0) {
            if (!confirm('EF commission rate is 0!')) {
                return false;
            }
        }
        if (document.MAINFORM.FA_EF_HAN_CHG_AMT.value == 0) {
            if (!confirm('EF handling charge per document is 0!')) {
                return false;
            }
        }
        if (document.MAINFORM.FA_IF_COMM_RT.value == 0) {
            if (!confirm('IF commission rate is 0!')) {
                return false;
            }
        }
        if (document.MAINFORM.FA_IF_HAN_CHG_AMT.value == 0) {
            if (!confirm('IF handling charge per document is 0!')) {
                return false;
            }
        }
        if (document.MAINFORM.FA_IRT_SPREAD.value == 0) {
            if (!confirm('Margin Rate is 0!')) {
                return false;
            }
        }
        if (document.MAINFORM.FA_OVD_IRT_SPREAD.value == 0) {
            if (!confirm('Penalty Interest Rate is 0!')) {
                return false;
            }
        }
        return true;
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

csFuncLevelProto.SYF_FADA_Chk_isEmpty = function(value) {
    try {

        if (value == null || value.length == 0) {
            return true;
        }
        return false;
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

csFuncLevelProto.PostconditionOnInit = function() {
    try {

        SYT_RELE_CREA_BY();
        if (SYS_FUNCTION_TYPE == 'EC' || SYS_FUNCTION_TYPE == 'PM') {
            document.MAINFORM.TRX_DT.value = SYS_BUSI_DATE;
            document.MAINFORM.CLERK_ID.value = SYS_USER_ID;
        }
        //for Documents:
        SYF_FADA_GET_FA_CUST_TYPE2();
        var custType = document.MAINFORM.FA_CUST_TYPE2.value;
        if (custType == "2") {
            document.MAINFORM.C_BU_ID.value = SYS_BUSI_UNIT;
        } else {
            document.MAINFORM.C_BU_ID.value = "DOC";
        }
        SYF_FADA_Get_FA_CNTR_DOC_NO();
        SYF_FADA_FA_SERVICE_REQ();

       SYS_GetTableDataByRule_S('Get_CE_MAIN_REF', '1', 'Y');
               alert(document.MAINFORM.FA_TEMP3.value);
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

csFuncLevelProto.SYF_FADA_Get_Buyer_Back = function() {
    try {

        var lmtCCY = document.MAINFORM.FA_APPL_LMT_CCY.value;
        if (lmtCCY != '' && lmtCCY != null) {
            document.MAINFORM.FA_EF_HAN_CHG_CCY.value = lmtCCY;
            document.MAINFORM.FA_EF_OTH_CHG_CCY.value = lmtCCY;
            document.MAINFORM.FA_IF_HAN_CHG_CCY.value = lmtCCY;
            document.MAINFORM.FA_IF_OTH_CHG_CCY.value = lmtCCY;
            document.MAINFORM.FA_OTH_CHG_CCY.value = lmtCCY;
            document.MAINFORM.FA_HAN_CHG_CCY.value = lmtCCY;
        }

        SYF_FADA_FA_SERVICE_REQ();
        SYF_FADA_Get_EDI4_information();
        SYF_FADA_IF_Handle_Charge();
        SYF_FADA_IF_Other_Charge();
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

csFuncLevelProto.SYF_FADA_Chk_TTL_Rate = function() {
    try {

        if (document.MAINFORM.FA_TTL_COMM_RT.value == 0) {
            SYS_CheckError(document.MAINFORM.FA_TTL_COMM_RT, 'Total commission rate cannot be zero! ');
            return false;
        }
        return true;
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

