csFuncLevelProto.SYF_FADA_IF_Handle_Charge = function() {
    try {

        if (document.MAINFORM.FA_REMI_CCY1.value != '' && document.MAINFORM.FA_APPL_LMT_CCY.value != '') {
            SYS_GetExchangeRate_S(document.MAINFORM.FA_REMI_CCY1.value, document.MAINFORM.FA_APPL_LMT_CCY.value, 'Booking Rate', 'EXCH_RT5');
        }
        var temp1 = SYS_BeFloat(document.MAINFORM.FA_TEMP1.value) * SYS_BeFloat(document.MAINFORM.EXCH_RT5.value);
        document.MAINFORM.FA_IF_HAN_CHG_AMT.value = SYT_AmtFormat(document.MAINFORM.FA_IF_HAN_CHG_CCY.value, temp1);
        SYF_FADA_Cal_FA_TTL_HAN_CHG();
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

csFuncLevelProto.SYF_FADA_IF_Other_Charge = function() {
    try {

        if (document.MAINFORM.FA_REMI_CCY2.value != '' && document.MAINFORM.FA_APPL_LMT_CCY.value != '') {
            SYS_GetExchangeRate_S(document.MAINFORM.FA_REMI_CCY2.value, document.MAINFORM.FA_APPL_LMT_CCY.value, 'Booking Rate', 'EXCH_RT6');
        }
        var temp2 = SYS_BeFloat(document.MAINFORM.FA_TEMP5.value) * SYS_BeFloat(document.MAINFORM.EXCH_RT6.value);
        document.MAINFORM.FA_IF_OTH_CHG_AMT.value = SYT_AmtFormat(document.MAINFORM.FA_IF_OTH_CHG_CCY.value, temp2);
        SYF_FADA_Cal_FA_TTL_OTH_CHG();
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

csFuncLevelProto.SYF_FADA_FA_SERVICE_REQ = function() {
    try {

        var servReq = document.MAINFORM.FA_SERVICE_REQ.value;
        if (servReq == '1' || servReq == '2') {
            SYF_FADA_MPO_LOAN_RT();
            SYT_ChangeFldClass(document.MAINFORM.FA_MAX_LOAN_PERC, 'M');
            SYT_ChangeFldClass(document.MAINFORM.FA_IRT_SPREAD, 'O');
            SYT_ChangeFldClass(document.MAINFORM.FA_OVD_IRT_SPREAD, 'O');
        } else if (servReq == '3') {
            document.MAINFORM.FA_MAX_LOAN_PERC.value = 0;
            document.MAINFORM.FA_IRT_SPREAD.value = 0;
            document.MAINFORM.FA_OVD_IRT_SPREAD.value = 0;
            SYT_ChangeFldClass(document.MAINFORM.FA_MAX_LOAN_PERC, 'P');
            SYT_ChangeFldClass(document.MAINFORM.FA_IRT_SPREAD, 'P');
            SYT_ChangeFldClass(document.MAINFORM.FA_OVD_IRT_SPREAD, 'P');
        }
    } catch (e) {
        DisExcpt("SYF_FADA_EFPricing.js", e);
    }
}

