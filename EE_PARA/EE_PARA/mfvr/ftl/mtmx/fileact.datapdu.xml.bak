<?xml version="1.0" encoding="utf-8"?>
<Saa:DataPDU xmlns:Saa="urn:swift:saa:xsd:saa.2.0" xmlns:Sw="urn:swift:snl:ns.Sw"
  xmlns:SwGbl="urn:swift:snl:ns.SwGbl" xmlns:SwInt="urn:swift:snl:ns.SwInt" xmlns:SwSec="urn:swift:snl:ns.SwSec">
  <Saa:Revision>2.0.14</Saa:Revision>
  <Saa:Header>
  <Saa:Message>
    <Saa:SenderReference>${sender_ref}</Saa:SenderReference>
    <Saa:MessageIdentifier>${msgidr}</Saa:MessageIdentifier>
    <Saa:Format>${format}</Saa:Format>
<#if "MT" == format>
    <Saa:Sender><Saa:BIC12>${sender_bic12}</Saa:BIC12></Saa:Sender>
    <Saa:Receiver><Saa:BIC12>${receiver_bic12}</Saa:BIC12></Saa:Receiver>
<#else>
    <Saa:Sender><Saa:DN>${sender_dn}</Saa:DN><Saa:FullName><Saa:X1>${sender_bic}</Saa:X1></Saa:FullName></Saa:Sender>
    <Saa:Receiver><Saa:DN>${receiver_dn}</Saa:DN><Saa:FullName><Saa:X1>${receiver_bic}</Saa:X1></Saa:FullName></Saa:Receiver>
</#if>
    <Saa:InterfaceInfo><Saa:UserReference>${user_ref}</Saa:UserReference></Saa:InterfaceInfo>
    <Saa:NetworkInfo>
<#if svc_name?has_content >
      <Saa:Service>${svc_name}</Saa:Service>
<#else>
      <Saa:Service>swift.corp.fast!x</Saa:Service>
</#if>
      <Saa:SWIFTNetNetworkInfo>
        <Saa:RequestType>${mxtype}</Saa:RequestType>
<#if bizsvc?has_content >
        <Saa:RequestSubtype>${bizsvc}</Saa:RequestSubtype>
</#if>
<#if compress?has_content >
        <Saa:FileInfo>SwCompression=${compress}</Saa:FileInfo>
</#if>
      </Saa:SWIFTNetNetworkInfo>
    </Saa:NetworkInfo>
  </Saa:Message></Saa:Header>
  <Saa:Body>${body}</Saa:Body>
</Saa:DataPDU>