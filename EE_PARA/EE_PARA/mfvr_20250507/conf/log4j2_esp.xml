<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </Console>
    <File name="File" fileName="/tmp/esp.log">
        <PatternLayout pattern="%d %p %C{1.} [%t] %m%n" />
    </File>
  </Appenders>
  <Loggers>
    <Logger name="ESPLOG" level="debug" additivity="false">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="File"/>
    </Logger>
    <Logger name="HEARTBEAT" level="debug" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="com.cs.esp.db" level="debug" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Logger name="test.cs" level="debug" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Root level="info">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>