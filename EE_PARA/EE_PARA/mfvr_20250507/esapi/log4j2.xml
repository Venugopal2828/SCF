<?xml version="1.0" encoding="UTF-8"?>  
<Configuration status="OFF">  
    <Properties>
        <Property name="user_level">user_level_log</Property>
        <Property name="sys_level">sys_level_log</Property>
         <Property name="LOG_PATTERN" value="%n[start] [%p] [%d{yyyy-MM-dd HH:mm:ss.SSS}] [%X{userID}] %msg [end]%n"/>
          <Property name="LOG_PATTERN_OLD" value="[Start] %d{yyyy-MM-dd 'at' HH:mm:ss z}  %-5level %n%msg%rEx{full}[End]%n"/>
        <Property name="LOG_DEBUG_LEVEL" value="DEBUG"/>
        <!-- error级别日志 -->
        <Property name="LOG_ERROR_LEVEL" value="error"/>
        <!-- 日志文件大小，超过这个大小将被压缩 -->
        <Property name="LOG_MAX_SIZE" value="10 MB"/>   
        <Property name="TIME_BASED_INTERVAL" value="1"/>
    </Properties>
    <Appenders>  
        <Console name="Console" target="SYSTEM_OUT">  
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %M() - %msg%n"/>
        </Console> 
        <Routing name="EELOGAppender">
            <Routes pattern="$${ctx:userID}">
                <Route>
                    <RollingFile name="EELogRolling" 
                                   filePattern="/tmp/EELog/$${date:yyyy-MM-dd}/${user_level}/%d{yyyy-MM-dd}_${ctx:userID}_EELog.log"
                                   immediateFlush="true" 
                                   append="true">

                        <PatternLayout pattern="${LOG_PATTERN}"/>
                        <Policies>
                            <!--interval属性用来指定多久滚动一次，根据当前filePattern设置是1天滚动一次-->
                            <TimeBasedTriggeringPolicy interval="${TIME_BASED_INTERVAL}"/>
                            <SizeBasedTriggeringPolicy size="${LOG_MAX_SIZE}"/>
                        </Policies>
                        <!-- DefaultRolloverStrategy属性如不设置，则默认同一文件夹下最多保存7个文件-->
                        <DirectWriteRolloverStrategy maxFiles="10"/>
                    </RollingFile>
                </Route>
            </Routes>
        </Routing>
        <Routing name="SysAppender">
            <Routes>
                <Route>
                    <RollingFile name="SysRollingFile" 
                                   filePattern="/tmp/EELog/$${date:yyyy-MM-dd}/${sys_level}/%d{yyyy-MM-dd}_SYSLog.log"
                                   immediateFlush="true" 
                                   append="true">

                        <PatternLayout pattern="${LOG_PATTERN}"/>
                        <Policies>
                            <!--interval属性用来指定多久滚动一次，根据当前filePattern设置是1天滚动一次-->
                            <TimeBasedTriggeringPolicy interval="${TIME_BASED_INTERVAL}"/>
                            <SizeBasedTriggeringPolicy size="${LOG_MAX_SIZE}"/>
                        </Policies>
                        <!-- DefaultRolloverStrategy属性如不设置，则默认同一文件夹下最多保存7个文件-->
                        <DirectWriteRolloverStrategy maxFiles="10"/>
                    </RollingFile>
                </Route>
            </Routes>
        </Routing>
         <Routing name="CSSOABrokerAppender">
            <Routes>
                <Route>
                    <RollingFile name="CSSOABrokerRollingFile" 
                                   filePattern="${sys:ee.input.dir}/EELog/$${date:yyyy-MM-dd}/${sys_level}/%d{yyyy-MM-dd}_CSSOA-BrokerLog.log" 
