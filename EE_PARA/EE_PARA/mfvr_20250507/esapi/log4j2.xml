                                filePattern="/tmp/EELog/$${date:yyyy-MM-dd}/${sys_level}/ssssss.log"
                                   immediateFlush="true" 
                                   append="true">
                        <Filters>
                            <ContextMapFilter onMatch="ACCEPT" onMismatch="DENY" operator="or">
                                <KeyValuePair key="LoggerName" value="A2D_NONE_Default_PERFORMANCELOG"/>
                                <KeyValuePair key="LoggerName" value="A2W_NONE_Default_PERFORMANCELOG"/>
                                <KeyValuePair key="LoggerName" value="ACCESSLOG"/>
                                <KeyValuePair key="LoggerName" value="ACCESSLOGINLOG"/>
                                <KeyValuePair key="LoggerName" value="APILOG"/>
                                <KeyValuePair key="LoggerName" value="ARCHIVINGLOG"/>
                                <KeyValuePair key="LoggerName" value="B2W_NONE_Default_PERFORMANCELOG"/>
                                <KeyValuePair key="LoggerName" value="BA"/>
                                <KeyValuePair key="LoggerName" value="BATCHCLUSTERLOG"/>
                                <KeyValuePair key="LoggerName" value="BATCHLOG"/>
                                <KeyValuePair key="LoggerName" value="TASKLOG"/>
                                <KeyValuePair key="LoggerName" value="CE-EE-DMS-SRV"/>
                                <KeyValuePair key="LoggerName" value="CE-EE-INQ-DATA"/>
                                <KeyValuePair key="LoggerName" value="CE-EE-CALC-FEE"/>
                                <KeyValuePair key="LoggerName" value="CE-EE-LOCK-INV"/>
                                <KeyValuePair key="LoggerName" value="CE-EE-EXPORT"/>
                                <KeyValuePair key="LoggerName" value="CE-EE-INV-SUM"/>
                                <KeyValuePair key="LoggerName" value="COMPLIANCELOG"/>
                                <KeyValuePair key="LoggerName" value="DMSINTFLOG"/>
                                <KeyValuePair key="LoggerName" value="COMPONENTLOG"/>
                                <KeyValuePair key="LoggerName" value="ESPLOG"/>
                                <KeyValuePair key="LoggerName" value="HEARTBEAT"/>
                                <KeyValuePair key="LoggerName" value="LIMITINTFLOG"/>
                                <KeyValuePair key="LoggerName" value="myBatis"/>
                                <KeyValuePair key="LoggerName" value="PAYMENTLOG"/>
                                <KeyValuePair key="LoggerName" value="PERFORMANCELOG"/>
                                <KeyValuePair key="LoggerName" value="RDMLOG"/>
                                <KeyValuePair key="LoggerName" value="REPORT"/>
                                <KeyValuePair key="LoggerName" value="scfMsgLog"/>
                                <KeyValuePair key="LoggerName" value="scfSQLLog"/>
                                <KeyValuePair key="LoggerName" value="SCHEDULELOG"/>
                                <KeyValuePair key="LoggerName" value="SMMSLOG"/>
                                <KeyValuePair key="LoggerName" value="STPLOG"/>
                                <KeyValuePair key="LoggerName" value="W2A_NONE_Default_PERFORMANCELOG"/>
                                <KeyValuePair key="LoggerName" value="BALOG"/>
                                <KeyValuePair key="LoggerName" value="ACTLOG"/> 
                                <KeyValuePair key="LoggerName" value="SECULOG"/> 
                                <KeyValuePair key="LoggerName" value="LMTSLOG"/> 
                                <KeyValuePair key="LoggerName" value="STANLOG"/> 
                                <KeyValuePair key="LoggerName" value="RECORDLOG"/> 
                                <KeyValuePair key="LoggerName" value="com.cs.esp.db"/> 

                            </ContextMapFilter>
                        </Filters>
                        <PatternLayout pattern="${LOG_PATTERN}"/>
                        <Policies>
                            <!--interval属性用来指定多久滚动一次，根据当前filePattern设置是1天滚动一次-->
                            <TimeBasedTriggeringPolicy interval="${TIME_BASED_INTERVAL}"/>
                            <SizeBasedTriggeringPolicy size="${LOG_MAX_SIZE}"/>
                        </Policies>
                        <!-- DefaultRolloverStrategy属性如不设置，则默认同一文件夹下最多保存7个文件-->
                        <DirectWriteRolloverStrategy maxFiles="10"/>
                    </RollingFile>
                </Route>
            </Routes>
        </Routing>  
    </Appenders>  
    <Loggers>  
        <Logger name="SYS_LOG" level="info"  additivity="false">  
            <AppenderRef ref="SysAppender" level="ALL"/>  
        </Logger>  
