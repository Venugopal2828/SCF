	<DESC>Upload Maintenance</DESC>
	<SQL>
		<![CDATA[ SELECT C_BK_GROUP_ID, C_CREATED_BU, C_CREATED_BY, C_DEAL_TYPE, C_FAIL_REASON, C_FILE_FROM, C_FILE_INDEX, C_FILE_MD5, C_FILE_NAME, C_FILE_STATUS, C_MSG_SET, C_PARTITION_STATUS, C_REFUSE_REASON, C_RELE_BU, C_RELE_BY, C_TRX_STATUS, D_RELE_DATE, D_RELE_DATE, I_FAIL_RECORDS, I_SUCC_RECORDS, I_TOTAL_RECORDS, T_CREA_TIME, T_RELE_TIME, C_EXTRA_CONFIG FROM CETRX.TRX_FILE_UPLOAD WHERE C_TRX_STATUS IN ('P','A','T','R','M') AND ((D_RELE_DATE >= TO_DATE(:startDay,'YYYY-MM-DD') AND D_RELE_DATE <= TO_DATE(:endDay,'YYYY-MM-DD')) OR D_RELE_DATE = TO_DATE(:currentDay,'YYYY-MM-DD')) ORDER BY D_RELE_DATE ]]>
	</SQL>
