	<CLAUSE/>
	<SQL>SELECT C_BK_GROUP_ID,LC_NO,C_TRX_REF,C_UNIT_CODE,PARENT_MAIN_REF,CUST_NO,C_MAIN_REF,BENE_NM,NEW_EXPIRY_DT,NO_OF_AMD,AMD_DT,C_TRX_STATUS,CURRNT_STATUS,I_EVENT_TIMES FROM CETRX.IMLC_EM_AMD WHERE C_BK_GROUP_ID = sv('bu.C_BK_GROUP_ID') AND (LOWER(C_MAIN_REF) like LOWER(:global) OR LOWER(C_UNIT_CODE) like LOWER(:global) OR LOWER(CUST_NO) LIKE LOWER(:global) OR LOWER(LC_NO) LIKE LOWER(:global) OR LOWER(BENE_NM) LIKE LOWER(:global)) ORDER BY C_MAIN_REF DESC,C_UNIT_CODE</SQL>
