	<DESC>Export Letters of Credit</DESC>
	<SQL><![CDATA[SELECT C_PRODUCT_ID,C_MAIN_REF,C_TRX_REF,I_EVENT_TIMES,C_BK_GROUP_ID,C_UNIT_CODE,ADV_NO,APPL_NM,BENE_NM,PARENT_MAIN_REF,LC_CCY,LC_AMT,ISSUE_DT,EXPIRY_DT,CURRNT_STATUS,C_TRX_STATUS,D_CREA_DATE FROM CETRX.EXLC_EM_ADV WHERE C_TRX_STATUS IN ('P','A','T','R','M') AND (EXPIRY_DT >= TO_DATE(:startDay, 'YYYY-MM-DD') AND EXPIRY_DT <= TO_DATE(:endDay, 'YYYY-MM-DD') AND EXPIRY_DT = TO_DATE(:currentDay, 'YYYY-MM-DD')) ORDER BY ADV_NO]]>
	</SQL>
