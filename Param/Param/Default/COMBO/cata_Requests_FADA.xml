	<DESC>SCF Program Maintenance</DESC>
	<SQL><![CDATA[ SELECT C_MAIN_REF, C_TRX_REF, C_UNIT_CODE, C_PRODUCT_ID, C_FUNC_SHORT_NAME, CURRNT_STATUS, C_TRX_STATUS, C_EVENT_NAME, C_EVENT_STATUS, C_NOW_EVENT, I_EVENT_TIMES, C_CUST_ID, FA_BUYER_ID, FA_ANCHOR_ID, FA_AGM_VAL_DT, FA_AGM_DUE_DT, FA_TRX_DT, D_CREA_DATE, C_LOCKED_FLAG FROM CETRX.FAEF_EM_INV WHERE C_TRX_STATUS IN ('P','A','T','R','M') AND ((FA_AGM_DUE_DT >= TO_DATE(:startDay,'YYYY-MM-DD') AND FA_AGM_DUE_DT <= TO_DATE(:endDay,'YYYY-MM-DD')) OR FA_AGM_DUE_DT = TO_DATE(:currentDay,'YYYY-MM-DD')) ORDER BY C_CUST_ID ]]>
	</SQL>
