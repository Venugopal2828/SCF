	<DESC>Audit Trail Report</DESC>
	<CLAUSE/>
	<SQL><![CDATA[SELECT C_USER_ID,C_MAIN_REF,C_IP_ADDRESS,C_FUNC_ID,C_PRODUCT_ID,C_FUNC_SHORT_NAME,C_MODULE,C_OP_USER,C_TRX_STATUS,C_UNIT_CODE,D_SYS_OP_DATE,T_SYS_OP_TIME,C_LOG_ID,C_ITEM_ID FROM CETRX.TRX_ACT_LOG WHERE (C_UNIT_CODE IN (SELECT C_CHILD_ID FROM CEUSER.SEC_UNIT_STRUC WHERE C_PARENT_ID = sv('bu.C_UNIT_CODE')) OR C_UNIT_CODE = sv('bu.C_UNIT_CODE')) AND (LOWER(C_USER_ID) LIKE LOWER(:global) OR LOWER(C_UNIT_CODE) LIKE LOWER(:global)) AND C_ITEM_ID <>'Unlock' AND D_SYS_OP_DATE >= TO_DATE((:startDay),'YYYY-MM-DD') AND  D_SYS_OP_DATE <= TO_DATE((:endDay),'YYYY-MM-DD') ORDER BY D_SYS_OP_DATE,T_SYS_OP_TIME]]></SQL>
