	<SQL>SELECT C_BK_GROUP_ID,C_MAIN_REF,C_TRX_REF,C_UNIT_CODE,PARENT_MAIN_REF,CUST_NO,LC_NO,BENE_NM,LC_CCY,LC_AMT,LC_BALA,EXPIRY_DT,C_TRX_STATUS,CURRNT_STATUS,I_EVENT_TIMES FROM CETRX.IMLC_EM_ISSUE WHERE C_BK_GROUP_ID = sv('bu.C_BK_GROUP_ID') AND (LOWER(C_MAIN_REF) like LOWER(:global) OR LOWER(C_UNIT_CODE) like LOWER(:global) OR LOWER(CUST_NO) LIKE LOWER(:global) OR LOWER(LC_NO) LIKE LOWER(:global) OR LOWER(BENE_NM) LIKE LOWER(:global)) ORDER BY C_MAIN_REF DESC,C_UNIT_CODE</SQL>
