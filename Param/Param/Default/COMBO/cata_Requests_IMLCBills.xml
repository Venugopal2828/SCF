		<FIELD ALIAS="" CONFIG="Y" DATATYPE="1" DESC="Beneficiary Name" EEType="NM_CHAR35" HIDDEN="" NOEVENT="Y" FILTER="Y" HYPERLINK="" OPTION="BENE_NM" OPTIONTYPE="distinctRecord" FILTERCONTROL="multi-select" ORIGINAL_FIELD="BENE_NM">BENE_NM</FIELD>
