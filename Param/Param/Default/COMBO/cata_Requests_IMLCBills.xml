	<PRODUCTS>
		<PRODUCT>P08071500000</PRODUCT>
	</PRODUCTS>
	<RESOURCE FILE="cata_resource.json" URL=""/>
	<BUILT_IN_COMPS>
		<COMPONENT NAME="StatusChip">
			<PARAMETERS>
				<PARAM NAME="StatusField" VALUE="CURRNT_STATUS" />
			</PARAMETERS>
			<EXPORT SOURCE="FIELD">CURRNT_STATUS</EXPORT>
		</COMPONENT>
	</BUILT_IN_COMPS>
	<MIXIN>
		<DEFAULT>
			<FIELD NAME="AMTCCY">
				<DISPLAY SOURCE="TMPL_FILE">REQ_DEFAULT_AMTCCY_D.ftl</DISPLAY>
				<EXPORT SOURCE="TMPL_FILE">REQ_DEFAULT_AMTCCY_E.ftl</EXPORT>
			</FIELD>
			<FIELD NAME="CCY">
				<DISPLAY SOURCE="FIELD">PRES_CCY</DISPLAY>
				<EXPORT SOURCE="FIELD">PRES_CCY</EXPORT>
			</FIELD>
			<FIELD NAME="AMOUNT">
				<DISPLAY SOURCE="FIELD">PRES_AMT</DISPLAY>
				<EXPORT SOURCE="FIELD">PRES_AMT</EXPORT>
			</FIELD>
		</DEFAULT>
		<MODULES/>
		<FUNCTIONS/>
	</MIXIN>
	<RECORDACTIONS>
		<DEFAULT>
			<ACTION TYPE="FUNC" DESC="View summary" VALUE="F05030701140"/><!--IMLC View Register Doc-->
			<ACTION TYPE="SYS" DESC="View related transactions" VALUE="ViewHistoryList"/>
		</DEFAULT>
		<MODULES/>
		<FUNCTIONS/>
	</RECORDACTIONS>
	<DESC>Letters of Credit Bills</DESC>
	<SQL><![CDATA[SELECT C_PRODUCT_ID,C_MAIN_REF,C_TRX_REF,I_EVENT_TIMES,C_BK_GROUP_ID,C_UNIT_CODE,PARENT_MAIN_REF,APPL_NM,CUST_NO,LC_NO,DRAW_NO,NO_OF_DRAW,BENE_NM,PRES_CCY,PRES_AMT,DUE_DT,CURRNT_STATUS,C_TRX_STATUS FROM CETRX.IMLC_EM_NEGO WHERE C_TRX_STATUS IN ('P','A','T','R','M') AND (DUE_DT >= TO_DATE(:startDay, 'YYYY-MM-DD') AND DUE_DT <= TO_DATE(:endDay, 'YYYY-MM-DD') AND DUE_DT = TO_DATE(:currentDay, 'YYYY-MM-DD')) ORDER BY CUST_NO]]>
	</SQL>
	<EXPORTTYPE>PDF,EXCEL,CSV</EXPORTTYPE>
	<QUICK_SEARCH>
		<FIELD DESC="Beneficiary">BENE_NM</FIELD>
		<FIELD DESC="Our Ref">CUST_NO</FIELD>
		<FIELD DESC="LC Ref">LC_NO</FIELD>
		<FIELD DESC="Drawing Ref">DRAW_NO</FIELD>
		<FIELD DESC="Company Code">C_UNIT_CODE</FIELD>
	</QUICK_SEARCH>
</CATA>
