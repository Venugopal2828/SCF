		<FIELD ALIAS="" CONFIG="Y" DATATYPE="12" DESC="LC Ref" EEType="RELATED_REF" HIDDEN="" NOEVENT="Y" FILTER="Y" HYPERLINK="" OPTION="" OPTIONTYPE="" FILTERCONTROL="text-input" ORIGINAL_FIELD="LC_NO">LC_NO</FIELD>
