		<FIELD ALIAS="" CONFIG="Y" DATATYPE="12" DESC="Status" EEType="NARR(1_35)" HIDDEN="H" NOEVENT="Y" FILTER="Y" HYPERLINK="" OPTION="CURRNT_STATUS" OPTIONTYPE="distinctRecord" FILTERCONTROL="status-select" ORIGINAL_FIELD="CURRNT_STATUS" FORMATTYPE="" COMPONENTNAME="">CURRNT_STATUS</FIELD>
		<FIELD ALIAS="" CONFIG="Y" DATATYPE="12" DESC="Status" EEType="SYS_VARCHAR_4" HIDDEN="H" NOEVENT="Y" FILTER="N" HYPERLINK="" OPTION="SystemConv" OPTIONTYPE="class" ORIGINAL_FIELD="C_TRX_STATUS">C_TRX_STATUS</FIELD>
