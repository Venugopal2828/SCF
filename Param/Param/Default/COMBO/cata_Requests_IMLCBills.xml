		<FIELD ALIAS="" CONFIG="Y" DATATYPE="12" DESC="Amount" EEType="AMT" HIDDEN="" NOEVENT="Y" FILTER="N" HYPERLINK="" OPTION="" OPTIONTYPE="" ORIGINAL_FIELD="AMTCCY" FORMATTYPE="MIXIN">AMTCCY</FIELD>
