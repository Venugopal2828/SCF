		<FIELD ALIAS="" CONFIG="Y" DATATYPE="3" DESC="Presentation Amount" EEType="AMT" HIDDEN="H" NOEVENT="Y" FILTER="Y" HYPERLINK="" OPTION="" OPTIONTYPE="" FILTERCONTROL="amount-range" ORIGINAL_FIELD="PRES_AMT">PRES_AMT</FIELD>
