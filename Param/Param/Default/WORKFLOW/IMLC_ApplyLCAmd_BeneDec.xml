<WORKFLOW>
	<STEPS>
		<STEP>
			<LABEL>Apply for Amendment</LABEL>
			<INITIALINFO>Draft</INITIALINFO>
			<FUNCS>
				<FUNC ID="F05030700940" DESC="IMLC Apply for Amendment"/>
				<FUNC ID="F05030700854" DESC="IMLC Resubmit Amendment"/>
			</FUNCS>
			<STATUSLIST>
				<CURRNTSTATUS/>
				<TRXSTATUS>
					<!--LEDGER-->
					<STATUS DESC="">Z</STATUS>
					<STATUS DESC="">P</STATUS>
				</TRXSTATUS>
			</STATUSLIST>
			<ENDSTATUS>Pending approval</ENDSTATUS><!--currnt status-->
			<ABNORMALSTATUS/>
			<ABINFO/>
			<EVENTINFO><![CDATA[by ${user} on ${date} at ${time}]]></EVENTINFO>
			<ENDINFO/>
		</STEP>
		<STEP>
			<LABEL>Authorize LC</LABEL>
			<INITIALINFO>Pending authorization</INITIALINFO>
			<FUNCS>
				<FUNC ID="F05030700940" DESC="IMLC Apply for Amendment"/>
				<FUNC ID="F05030700854" DESC="IMLC Resubmit Amendment"/>
			</FUNCS>
			<STATUSLIST>
				<CURRNTSTATUS/>
				<TRXSTATUS>
					<!--LEDGER-->
					<STATUS DESC="">T</STATUS>
					<STATUS DESC="">S</STATUS>
					<STATUS DESC="">R</STATUS>
				</TRXSTATUS>
			</STATUSLIST>
			<ENDSTATUS>Fully authorized</ENDSTATUS><!--currnt status-->
			<ABNORMALSTATUS>Rejected by authorizer</ABNORMALSTATUS>
			<ABINFO><![CDATA[by ${user} on ${date} at ${time}]]></ABINFO>
			<EVENTINFO><![CDATA[next authorizers]]></EVENTINFO>
			<ENDINFO><![CDATA[authorized by ${count} users]]></ENDINFO>
		</STEP>
		<STEP>
			<LABEL>Bank Decision</LABEL>
			<INITIALINFO>Application review</INITIALINFO>
			<FUNCS>
				<FUNC ID="F05030700861" DESC="Bank Decision on Amendment Application"/>
			</FUNCS>
			<STATUSLIST>
				<CURRNTSTATUS>
					<STATUS DESC="Amendment accepted">Accepted by bank</STATUS><!--IMLC  Bank Review: Accept-->
					<STATUS DESC="Amendment rejected">Rejected by bank</STATUS><!--IMLC Bank Review: Reject-->
				</CURRNTSTATUS>
				<TRXSTATUS>
					<!--LEDGER-->
					<STATUS DESC="">M</STATUS>
				</TRXSTATUS>
			</STATUSLIST>
			<ENDSTATUS>Accepted by bank</ENDSTATUS>
			<ABNORMALSTATUS>Rejected by bank</ABNORMALSTATUS>
			<ABINFO/>
			<EVENTINFO><![CDATA[by bank on ${date} at ${time}]]></EVENTINFO>
			<ENDINFO/>
		</STEP>
		<STEP>
			<LABEL>Beneficiary Decision</LABEL>
			<INITIALINFO>In process</INITIALINFO>
			<FUNCS>
				<FUNC ID="F05030700864" DESC="Received Beneficiary Decision"/>
				<FUNC ID="F05030700862" DESC="Received Beneficiary Consent"/>
				<FUNC ID="F05030700860" DESC="IMLC Amended"/>
			</FUNCS>
			<STATUSLIST>
				<CURRNTSTATUS>
					<STATUS DESC="">Beneficiary rejected</STATUS>
					<STATUS DESC="">Amended</STATUS>
					<STATUS DESC="">Waiting for beneficiary response</STATUS>
				</CURRNTSTATUS>
				<TRXSTATUS/>
			</STATUSLIST>
			<ENDSTATUS>Amended</ENDSTATUS>
			<ABNORMALSTATUS>Beneficiary rejected</ABNORMALSTATUS>
			<ABINFO/>
			<EVENTINFO><![CDATA[by beneficiary on ${date} at ${time}]]></EVENTINFO>
			<ENDINFO/>
		</STEP>
	</STEPS>
</WORKFLOW>