			<EVENTINFO><![CDATA[on ${date} at ${time}]]></EVENTINFO>
			<ABNORMALSTATUS/>
			<ABINFO/>
			<ENDINFO/>
		</STEP>
		<STEP>
			<LABEL>Export LC Advise</LABEL>
			<INITIALINFO>Export LC Advise</INITIALINFO>
			<FUNCS>
				<FUNC ID="F05030700899" DESC="Export LC Advise"/>
			</FUNCS>
			<STATUSLIST>
				<CURRNTSTATUS/>
