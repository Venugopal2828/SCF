[01]  [Id=C2A_InProgress_Maker]  SELECT T1.C_BK_GROUP_ID, T1.C_MAIN_REF, T1.C_TRX_REF, T1.C_UNIT_CODE, T1.PARENT_MAIN_REF, T1.C_TRX_STATUS, T1.CURRNT_STATUS, (CASE WHEN T1.C_MODULE = 'FADA' OR T1.C_MODULE = 'FAEF' THEN T1.C_TRX_STATUS ELSE T1.C2A_STATUS END) C2A_STATUS, T1.I_EVENT_TIMES, T1.C_MODULE, T1.C_FUNC_ID, T1.C_PRODUCT_ID, T1.C_TRX_ID, T3.C_LOCKED_FLAG, T3.C_LOCKED_OP, T3.C_USER_DESC, T1.D_SYS_OP_DATE, T1.T_SYS_OP_TIME, T1.C2A_CCY, T1.C2A_AMOUNT, T1.C2A_COUNTERPARTY FROM CETRX.TRX_INBOX T1 LEFT JOIN CETRX.TRX_LOCK_INFO T3 ON T1.C_MAIN_REF = T3.C_MAIN_REF AND T1.C_UNIT_CODE = T3.C_UNIT_CODE WHERE   T1.C_BK_GROUP_ID = 'CSBANK'  AND (( T1.C_UNIT_CODE = 'C008556'  AND  T1.C_PRODUCT_ID IN ('FHS0YffwVNuA','P19080800000','P19080800001','P19080800002','P20030600000','epF3a6u4ZGAt') )) AND (T1.C_TRX_STATUS IN ('P', 'T', 'A', 'S') AND (T1.C_MODULE = 'IMLC' OR T1.C_MODULE = 'EXLC' OR T1.C_MODULE = 'FAEF' OR T1.C_MODULE = 'FADA' OR T1.C_MODULE = 'ABLF') AND T1.C2A_STATUS NOT IN ('Discrepancies rejected_fully authorized') OR T1.C_TRX_STATUS = 'M' AND (T1.C_MODULE = 'IMLC' AND T1.C2A_STATUS NOT IN ('Issued', 'Amended', 'Beneficiary rejected', 'Settled') OR T1.C_MODULE = 'EXCO' AND T1.CURRNT_STATUS NOT IN ('Payment Advice') OR T1.C_MODULE = 'EXLC' AND T1.CURRNT_STATUS NOT IN ('Settled', 'Advise Received', 'Amendment Received', 'Docment Received') OR T1.C_MODULE = 'FAEF' AND T1.CURRNT_STATUS NOT IN ('Settled', 'Advise Received') OR T1.C_MODULE = 'FADA' AND T1.CURRNT_STATUS NOT IN ('Settled', 'Advise Received') OR T1.C_MODULE = 'ABLF' AND T1.CURRNT_STATUS NOT IN ('Settled', 'Advise Received'))) AND T1.C_TRX_ID NOT IN (SELECT C_TRX_ID FROM CETRX.TRX_USER_DISMISS WHERE C_USER_ID = 'C008556MCM1' AND C_GRP_CODE = 'C008556') AND (T1.C_MODULE = 'IMLC' OR T1.C_MODULE = 'EXLC' OR T1.C_MODULE = 'FAEF' OR T1.C_MODULE = 'FADA' OR T1.C_MODULE = 'ABLF') ORDER BY T1.D_SYS_OP_DATE DESC, T1.T_SYS_OP_TIME DESC
