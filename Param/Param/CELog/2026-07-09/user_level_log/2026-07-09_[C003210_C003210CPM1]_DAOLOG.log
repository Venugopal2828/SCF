[01]  [Id=C2A_ForYou]  SELECT COUNT(*) FROM (SELECT DISTINCT T1.C_BK_GROUP_ID, T1.C_MAIN_REF, T1.C_TRX_REF, T1.C_UNIT_CODE, T1.PARENT_MAIN_REF, T1.C_TRX_STATUS, T1.CURRNT_STATUS, T1.C2A_STATUS, T1.I_EVENT_TIMES, T1.C_MODULE, T1.C_FUNC_ID, T1.C_PRODUCT_ID, T1.C_TRX_ID, T3.C_LOCKED_FLAG, T3.C_LOCKED_OP, T3.C_USER_DESC, T1.D_SYS_OP_DATE, T1.T_SYS_OP_TIME, T1.C2A_CCY, T1.C2A_AMOUNT, T1.C2A_COUNTERPARTY FROM CETRX.TRX_INBOX T1 LEFT JOIN CETRX.TRX_NEXT_FUNC T2 ON T1.C_PRODUCT_ID = T2.C_PRODUCT_ID AND T1.C2A_STATUS = T2.C2A_STATUS AND T1.C_TRX_STATUS = T2.C_TRX_STATUS LEFT JOIN CETRX.TRX_LOCK_INFO T3 ON T1.C_MAIN_REF = T3.C_MAIN_REF AND T1.C_UNIT_CODE = T3.C_UNIT_CODE WHERE   T1.C_BK_GROUP_ID = 'CSBANK'  AND (( T1.C_UNIT_CODE = 'C003210'  AND  T1.C_PRODUCT_ID IN ('FHS0YffwVNuA','P19080800000','P19080800001','P19080800002','epF3a6u4ZGAt') )) AND (T2.C_NEXT_FUNC_ID IN (SELECT C_FUNC_ID FROM CEUSER.SEC_OP_FUNC WHERE C_USER_ID = 'C003210CPM1' AND C_GRP_CODE = 'C003210' AND C_UNIT_CODE = T1.C_UNIT_CODE) OR T2.C_NEXT_FUNC_ID IN (SELECT C_FUNC_ID FROM CEUSER.SEC_OP_FUNC WHERE C_GRP_CODE = 'C003210' AND C_USER_ID IN (SELECT C_ROLE_ID FROM CEUSER.SEC_USER_ROLE WHERE C_USER_ID = 'C003210CPM1' AND C_GRP_CODE = 'C003210') AND C_UNIT_CODE = T1.C_UNIT_CODE)) AND (T1.C_TRX_STATUS = 'R' OR T1.C2A_STATUS IN ('Rejected by bank', 'Discrepancy notification', 'Document received') AND T1.C_TRX_STATUS = 'M' OR T1.C2A_STATUS IN ('Amendment(Detrimental)_fully authorized', 'Document discrepancy_fully authorized') AND T1.C_TRX_STATUS = 'A') AND T1.C_TRX_ID NOT IN (SELECT C_TRX_ID FROM CETRX.TRX_USER_DISMISS WHERE C_USER_ID = 'C003210CPM1' AND C_GRP_CODE = 'C003210') AND (T1.C_MODULE = 'IMLC' OR T1.C_MODULE = 'EXLC' OR T1.C_MODULE = 'FAEF' OR T1.C_MODULE = 'FADA' OR T1.C_MODULE = 'TSUM' OR T1.C_MODULE = 'ABLF' OR T1.C_MODULE = 'UPLD') ORDER BY T1.D_SYS_OP_DATE DESC, T1.T_SYS_OP_TIME DESC)
