[01]  [Id=C2A_PendingApproval]  SELECT T1.C_BK_GROUP_ID, T1.C_MAIN_REF, T1.C_TRX_REF, T1.C_UNIT_CODE, T1.PARENT_MAIN_REF, T1.C_TRX_STATUS, T1.CURRNT_STATUS, T1.I_EVENT_TIMES, T1.C_MODULE, T1.C_FUNC_ID, T1.C_PRODUCT_ID, T1.C_TRX_ID, T1.C_CREATED_BY, T3.C_LOCKED_FLAG, T3.C_LOCKED_OP, T3.C_USER_DESC, T1.D_SYS_OP_DATE, T1.T_SYS_OP_TIME, T1.C2A_CCY, T1.C2A_AMOUNT, T1.C2A_COUNTERPARTY FROM CETRX.TRX_INBOX T1 LEFT JOIN CETRX.TRX_LOCK_INFO T3 ON T1.C_MAIN_REF = T3.C_MAIN_REF AND T1.C_UNIT_CODE = T3.C_UNIT_CODE WHERE   T1.C_BK_GROUP_ID = 'CSBANK'  AND  T1.C_UNIT_CODE = 'C003526'  AND  T1.C_PRODUCT_ID = 'P19080800001'   AND  T1.C_BK_GROUP_ID = 'CSBANK'  AND (T1.C_TRX_STATUS<>'R' AND T1.C_TRX_STATUS<>'A' OR T1.C_TRX_STATUS IS NULL) AND T1.C_TRX_ID NOT IN (SELECT C_TRX_ID FROM CETRX.TRX_AUTH_LIST WHERE  C_GRP_CODE = 'C003526'  AND  C_USER_ID = 'C003526CPM1'  AND  C_UNIT_CODE = 'C003526' ) AND T1.C_TRX_ID IN (SELECT C_TRX_ID FROM CETRX.TRX_MATRIX_LIST WHERE  C_UNIT_CODE = 'C003526'  AND ( (  I_AUTH_LEVEL = 1  AND  C_PRODUCT_ID = 'P19080800001' ))) AND (( T1.C_UNIT_CODE = 'C003526'  AND  T1.C_PRODUCT_ID IN ('FHS0YffwVNuA','P19080800000','P19080800001','P19080800002','P20030600000','epF3a6u4ZGAt') )) AND T1.C_TRX_STATUS IN ('P', 'T') AND (T1.C_MODULE = 'IMLC' OR T1.C_MODULE = 'EXLC' OR T1.C_MODULE = 'FAEF' OR T1.C_MODULE = 'FADA' OR T1.C_MODULE = 'ABLF') ORDER BY T1.D_SYS_OP_DATE DESC, T1.T_SYS_OP_TIME DESC
