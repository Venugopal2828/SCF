[01]  SELECT * FROM ( WITH EXCO_M1_TEMP AS(SELECT C_MAIN_REF,C_UNIT_CODE, COLL_NO AS CASEID FROM CETRX.EXCO_EM_CREATE WHERE  (( C_UNIT_CODE = 'SELLER'  AND  C_PRODUCT_ID IN ('P05122400001','P06022700000','P08071500003','P08071500004','P08071500005','P08080600000','P08091000000') )) AND  1 = 1  AND C_TRX_STATUS IN ('S','M') AND  1 = 1  AND  1 = 1  AND  COLL_CCY IN ('USD')  AND  DRWE_NM IN ('BUYER') )SELECT '1' AS SEQUENCE,'N' AS FLAG,'EXCO' AS REPORT_PDT,EXCO_M1.COLL_NO AS CASEID,'Export Collection' AS REPORTPRODUCT,EXCO_M1.DRWE_NM AS COUNTERPARTY,EXCO_M1.C_TRX_REF AS TRANREF,'Collection No' AS REFTYPE,NULL AS ISSUEDATE,EXCO_M1.COLL_CCY AS CURRENCY,EXCO_M1.COLL_AMT AS AMOUNT,EXCO_M1.CURRNT_STATUS AS STATUS,EXCO_M1.C_UNIT_CODE AS COMPANYCODE FROM CETRX.EXCO_EM_CREATE EXCO_M1 JOIN EXCO_M1_TEMP ON EXCO_M1.C_MAIN_REF = EXCO_M1_TEMP.C_MAIN_REF AND EXCO_M1.C_UNIT_CODE = EXCO_M1_TEMP.C_UNIT_CODE UNION ALL SELECT '2' AS SEQUENCE,'Y' AS FLAG,'EXCO' AS REPORT_PDT,EXCO_M1_E1.COLL_NO AS CASEID,'Export Collection' AS REPORTPRODUCT,NULL AS COUNTERPARTY,EXCO_M1_E1.C_TRX_REF AS TRANREF,'Collection No' AS REFTYPE,NULL AS ISSUEDATE,NULL AS CURRENCY,NULL AS AMOUNT,EXCO_M1_E1.CURRNT_STATUS AS STATUS,EXCO_M1_E1.C_UNIT_CODE AS COMPANYCODE FROM CETRX.EXCO_EM_AMD EXCO_M1_E1 JOIN EXCO_M1_TEMP ON EXCO_M1_E1.COLL_NO = EXCO_M1_TEMP.CASEID AND EXCO_M1_E1.C_UNIT_CODE = EXCO_M1_TEMP.C_UNIT_CODE) COMBO ORDER BY SEQUENCE,CASEID 
