<root>
	<charts>
		<chart type="cluster" desc="Clustered bar chart">
			<clause type="open"/>
		</chart>
		<chart type="pie" desc="Pie chart">
			<clause type="open"/>
		</chart>
		<chart type="stack" desc="Stacked bar chart" displayCount="T">
			<clause type="open"/>
			<clause type="all">
				<range value="3" type="YEAR"/>
			</clause>
		</chart>
	</charts>
	<output>
		<desc name="CIF">Company code</desc>
		<desc name="counterParty">Counterparty</desc>
		<desc name="OTHER">Open ended</desc>
	</output>
	<currency>
		<region value="Default">
			<ccy name="USD"/>
		</region>
	</currency>
</root>
