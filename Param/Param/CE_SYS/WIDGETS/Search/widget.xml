<?xml version="1.0" encoding="UTF-8"?>
<iw:iwidget xmlns:iw="http://www.ibm.com/xmlns/prod/iWidget" 
			id="Search"
			allowInstanceContent="false"
			supportedModes="view config"
			supportedWindowStates="maximize minimize"
			iScope="com.cs.widgets.Search" 
			lang="">
	<iw:resource globalid="com.cs.resources.SearchJs" src="Search/search.js"/>
	<iw:resource globalid="com.cs.resources.SearchCss" src="Search/search.css"/>
	<iw:itemSet id="idescriptor">
		<iw:item id="title" alias="title" lang=""
				 readOnly="false" value="Search">
				 <iw:alt lang="AR" value="البحث"/>
				 <iw:alt lang="FR" value="Rechercher"/>
		</iw:item>
	</iw:itemSet>
	<iw:itemSet id="labels">
	         <iw:item id="trxSearch" alias="trx" lang=""
				 readOnly="true" value="Transaction Search">
			<iw:alt lang="AR" value="البحث عن الحركات"/>
			<iw:alt lang="FR" value="Recherche de transactions"/>
		</iw:item>
		<iw:item id="funcSearch" alias="func" lang=""
				 readOnly="true" value="Function Search">
			<iw:alt lang="AR" value="وظيفة البحث"/>
			<iw:alt lang="FR" value="Recherche de fonction"/>
		</iw:item>
		<iw:item id="trxSearchBtn" alias="btn" lang=""
				 readOnly="true" value="Search">
			<iw:alt lang="AR" value="البحث"/>
			<iw:alt lang="FR" value="Rechercher"/>
		</iw:item>
		<iw:item id="mainRef" alias="ref" lang=""
				 readOnly="true" value="Main Reference">
			<iw:alt lang="AR" value="المرجع الرئيسي"/>
			<iw:alt lang="FR" value="Référence principale"/>
		</iw:item>
    </iw:itemSet>
	<iw:content mode="view"><![CDATA[
		<div class="com-cs-widget-Search"><ul/></div>
	]]></iw:content>
</iw:iwidget>